{
  "version": "2.0",
  "description": "Mean Reversion Strategy Configuration - T324 Tuned Parameters",
  "author": "Ivan (ML Engineer)",
  "date": "2026-04-03",
  "parameters": {
    "lookbackPeriods": 20,
    "zScoreThreshold": 2.0,
    "minVolume": 50000,
    "maxHoldDays": 5,
