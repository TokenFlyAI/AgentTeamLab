FROM node:20-alpine
WORKDIR /app

# Copy backend code
COPY . /app/

# Create output directories for shared data
RUN mkdir -p /app/output /app/../grace/output

# Install any required dependencies
RUN if [ -f package.json ]; then npm ci --omit=dev; fi

EXPOSE 3200
ENV PORT=3200
ENV NODE_ENV=production

CMD ["node", "dashboard_api.js"]
