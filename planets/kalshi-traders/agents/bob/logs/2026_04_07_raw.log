l check_exposure_limit(uint64_t additional_exposure_cents, const RiskSummary& summary) const noexcept {\nbackend/cpp_engine/engine.cpp:627:        return summary.total_exposure_cents + additional_exposure_cents <= config::MAX_TOTAL_EXPOSURE_CENTS;\nbackend/cpp_engine/engine.cpp:641:            update_circuit_breaker_internal(true, now_us);\nbackend/cpp_engine/engine.cpp:645:    bool update_circuit_breaker(bool is_loss, TimestampUs now_us) {\nbackend/cpp_engine/engine.cpp:647:        return update_circuit_breaker_internal(is_loss, now_us);\nbackend/cpp_engine/engine.cpp:650:    void reset_circuit_breaker() {\nbackend/cpp_engine/engine.cpp:652:        circuit_breaker_active_ = false;\nbackend/cpp_engine/engine.cpp:663:        int64_t peak_capital = static_cast<int64_t>(config::STARTING_CAPITAL_CENTS) + peak_total_pnl_cents_;\nbackend/cpp_engine/engine.cpp:664:        int64_t current_capital = static_cast<int64_t>(config::STARTING_CAPITAL_CENTS) + total_pnl;\nbackend/cpp_engine/engine.cpp:665:        if (peak_capital <= 0) {\nbackend/cpp_engine/engine.cpp:669:        if (current_capital >= peak_capital) {\nbackend/cpp_engine/engine.cpp:673:        summary.max_drawdown_percent = static_cast<double>(peak_capital - current_capital) / static_cast<double>(peak_capital) * 100.0;\nbackend/cpp_engine/engine.cpp:680:    bool circuit_breaker_active_;\nbackend/cpp_engine/engine.cpp:681:    TimestampUs circuit_breaker_triggered_at_;\nbackend/cpp_engine/engine.cpp:684:    bool update_circuit_breaker_internal(bool is_loss, TimestampUs now_us) {\nbackend/cpp_engine/engine.cpp:692:            circuit_breaker_active_ = true;\nbackend/cpp_engine/engine.cpp:693:            circuit_breaker_triggered_at_ = now_us;\nbackend/cpp_engine/engine.cpp:1156:        risk_summary_.total_exposure_cents = 0;\nbackend/cpp_engine/engine.cpp:1158:        risk_summary_.circuit_breaker_triggered = false;\nbackend/cpp_engine/engine.cpp:1260:                        risk_summary_.total_exposure_cents += order