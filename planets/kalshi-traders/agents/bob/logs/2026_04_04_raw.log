r] = prices;\n403\t  }\n404\t\n405\t  return priceData;\n406\t}\n407\t\n408\t// ---------------------------------------------------------------------------\n409\t// Main — Standalone Runner\n410\t// ---------------------------------------------------------------------------\n411\tfunction runSignalGeneration(correlationPairsInput) {\n412\t  // Load correlation pairs\n413\t  let correlationPairs;\n414\t  if (correlationPairsInput) {\n415\t    correlationPairs = correlationPairsInput;\n416\t  } else {\n417\t    const cpPath = path.join(__dirname, \"../../../public/correlation_pairs.json\");\n418\t    if (!fs.existsSync(cpPath)) {\n419\t      console.error(\"correlation_pairs.json not found. Run the pipeline first (Phases 1-3).\");\n420\t      process.exit(1);\n421\t    }\n422\t    correlationPairs = JSON.parse(fs.readFileSync(cpPath, \"utf8\"));\n423\t  }\n424\t\n425\t  console.log(\"\\n\" + \"=\".repeat(60));\n426\t  console.log(\"SIGNAL GENERATION — T555\");\n427\t  console.log(\"Z-Score Mean Reversion on Correlated Pairs\");\n428\t  console.log(\"=\".repeat(60));\n429\t  console.log(`Input: ${correlationPairs.total_pairs_analyzed || 0} pairs, ${correlationPairs.arbitrage_opportunities || 0} arb opportunities`);\n430\t  console.log(`Config: z_entry=${SIGNAL_CONFIG.zScoreEntry}, z_exit=${SIGNAL_CONFIG.zScoreExit}, z_stop=${SIGNAL_CONFIG.zScoreStop}`);\n431\t\n432\t  // Generate price data for simulation\n433\t  const priceData = generatePriceData(correlationPairs);\n434\t  console.log(`Generated ${Object.keys(priceData).length} price series (${SIGNAL_CONFIG.priceHistoryLength} ticks each)`);\n435\t\n436\t  // Generate signals\n437\t  const signals = generateSignals(correlationPairs, priceData);\n438\t  console.log(`\\nSignals generated: ${signals.length}`);\n439\t  console.log(`  ENTRY: ${signals.filter(s => s.type === \"ENTRY\").length}`);\n440\t  console.log(`  EXIT:  ${signals.filter(s => s.type === \"EXIT\").length}`);\n441\t  console.log(`  STOP:  ${signals.filt