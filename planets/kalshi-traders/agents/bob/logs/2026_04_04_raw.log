{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013tUn4CVVX97ZC7FppqqpUs","type":"tool_result","content":"1\t#!/usr/bin/env node\n2\t/**\n3\t * Walk-Forward Validation + Position Sizing — T580\n4\t *\n5\t * Consumes Bob's signals.json (does NOT regenerate signals).\n6\t * Adds:\n7\t *   1. Rolling window walk-forward with train/test split\n8\t *   2. Kelly criterion position sizing\n9\t *   3. Slippage modeling (bid-ask spread impact)\n10\t *   4. Max drawdown tracking with circuit breaker\n11\t *\n12\t * Run: node walk_forward_backtest.js\n13\t * Author: Alice (Lead Coordinator) — picking up for idle Dave\n14\t */\n15\t\n16\tconst fs = require('fs');\n17\tconst path = require('path');\n18\t\n19\t// --- Configuration ---\n20\tconst CONFIG = {\n21\t  // Walk-forward\n22\t  trainRatio: 0.6,          // 60% train, 40% test per window\n23\t  windowCount: 3,           // number of rolling windows\n24\t  // Kelly criterion\n25\t  kellyFraction: 0.25,      // quarter-Kelly for safety\n26\t  maxKellyBet: 0.10,        // max 10% of capital per trade\n27\t  // Slippage\n28\t  slippageBps: 50,          // 50 basis points slippage (bid-ask spread)\n29\t  tradingFeePct: 0.01,      // 1% trading fee per side\n30\t  // Risk management\n31\t  maxDrawdownPct: 15,       // circuit breaker at 15% drawdown\n32\t  initialCapital: 1000,     // $1000 starting capital\n33\t  contractValue: 1,         // $1 per contract on Kalshi\n34\t};\n35\t\n36\t// --- Load Signals ---\n37\tfunction loadSignals() {\n38\t  const signalPaths = [\n39\t    path.join(__dirname, '..', 'bob', 'signals.json'),\n40\t    path.join(__dirname, '..', '..', 'output', 'bob', 'signals.json'),\n41\t  ];\n42\t\n43\t  for (const p of signalPaths) {\n44\t    try {\n45\t      const data = JSON.parse(fs.readFileSync(p, 'utf8'));\n46\t      const signals = data.signals || data;\n47\t      if (Array.isArray(signals) && signals.length > 0) {\n48\t        console.log(`Loaded ${signals.length} signals from ${p}`);\n49\t        return { signals, config: data.config || {} };\n50\t      }\n51\t    } catch {}\n52\t  }\n53\t\n54\t  console.error('ERROR: Cannot find signals.json. This script consumes Bob\\'s signals — does NOT regenerate.');\n55\t  process.exit(1);\n56\t}\n57\t\n58\t// --- Kelly Criterion Position Sizing ---\n59\tfunction kellySize(winRate, avgWin, avgLoss, capital) {\n60\t  if (avgLoss === 0 || winRate === 0) return 0;\n61\t  const b = avgWin / avgLoss;  // win/loss ratio\n62\t  const q = 1 - winRate;\n63\t  const kelly = (winRate * b - q) / b;\n64\t\n65\t  // Apply fraction and cap\n66\t  const adjustedKelly = Math.max(0, kelly) * CONFIG.kellyFraction;\n67\t  const maxBet = capital * CONFIG.maxKellyBet;\n68\t  const betSize = Math.min(adjustedKelly * capital, maxBet);\n69\t\n70\t  return Math.max(0, Math.floor(betSize / CONFIG.contractValue));\n71\t}\n72\t\n73\t// --- Slippage Model ---\n74\tfunction applySlippage(price, direction) {\n75\t  const slippage = CONFIG.slippageBps / 10000;\n76\t  if (direction === 'BUY') return price * (1 + slippage);\n77\t  return price * (1 - slippage);\n78\t}\n79\t\n80\t// --- Walk-Forward Engine ---\n81\tfunction walkForward(signals) {\n82\t  const entrySignals = signals.filter(s => s.type === 'ENTRY');\n83\t  const exitSignals = signals.filter(s => s.type === 'EXIT');\n84\t\n85\t  if (entrySignals.length < CONFIG.windowCount * 2) {\n86\t    console.warn(`Only ${entrySignals.length} entry signals — using single window`);\n87\t    return [{ train: entrySignals.slice(0, Math.floor(entrySignals.length * CONFIG.trainRatio)),\n88\t              test: entrySignals.slice(Math.floor(entrySignals.length * CONFIG.trainRatio)),\n89\t              exits: exitSignals }];\n90\t  }\n91\t\n92\t  const windowSize = Math.floor(entrySignals.length / CONFIG.windowCount);\n93\t  const windows = [];\n94\t\n95\t  for (let i = 0; i < CONFIG.windowCount; i++) {\n96\t    const start = i * windowSize;\n97\t    const end = Math.min(start + windowSize, entrySignals.length);\n98\t    const window = entrySignals.slice(start, end);\n99\t    const splitIdx = Math.floor(window.length * CONFIG.trainRatio);\n100\t\n101\t    windows.push({\n102\t      windowNum: i + 1,\n103\t      train: window.slice(0, splitIdx),\n104\t      test: window.slice(splitIdx),\n105\t      exits: exitSignals.filter(e => {\n106\t        const eTime = new Date(e.timestamp).getTime();\n107\t        const wStart = new Date(window[0].timestamp).getTime();\n108\t        const wEnd = new Date(window[window.length - 1].timestamp).getTime();\n109\t        return eTime >= wStart && eTime <= wEnd + 86400000;\n110\t      }),\n111\t    });\n112\t  }\n113\t\n114\t  return windows;\n115\t}\n116\t\n117\t// --- Simulate Trades in a Window ---\n118\tfunction simulateWindow(entries, exits, capital, label) {\n119\t  let currentCapital = capital;\n120\t  let peakCapital = capital;\n121\t  let maxDrawdown = 0;\n122\t  let maxDrawdownPct = 0;\n123\t  let circuitBroken = false;\n124\t  const trades = [];\n125\t\n126\t  // Compute running stats for Kelly from prior trades\n127\t  let wins = 0, losses = 0, totalWinAmt = 0, totalLossAmt = 0;\n128\t\n129\t  for (const entry of entries) {\n130\t    // Circuit breaker check\n131\t    const currentDrawdownPct = ((peakCapital - currentCapital) / peakCapital) * 100;\n132\t    if (currentDrawdownPct >= CONFIG.maxDrawdownPct) {\n133\t      circuitBroken = true;\n134\t      break;\n135\t    }\n136\t\n137\t    // Find matching exit\n138\t    const exit = exits.find(e =>\n139\t      (e.market_a === entry.market_a && e.market_b === entry.market_b) &&\n140\t      new Date(e.timestamp) > new Date(entry.timestamp)\n141\t    );\n142\t\n143\t    // Kelly position sizing\n144\t    const winRate = (wins + losses) > 0 ? wins / (wins + losses) : 0.5;\n145\t    const avgWin = wins > 0 ? totalWinAmt / wins : 0.05;\n146\t    const avgLoss = losses > 0 ? totalLossAmt / losses : 0.03;\n147\t    const contracts = kellySize(winRate, avgWin, avgLoss, currentCapital);\n148\t\n149\t    if (contracts === 0) continue;\n150\t\n151\t    // Compute P&L with slippage\n152\t    const entrySpread = entry.spread || 0.05;\n153\t    const exitSpread = exit ? (exit.spread || 0.03) : entrySpread * 0.9;\n154\t\n155\t    const entryPrice = applySlippage(entrySpread, 'BUY');\n156\t    const exitPrice = applySlippage(exitSpread, 'SELL');\n157\t    const rawPnL = (exitPrice - entryPrice) * contracts * 100; // cents to dollars\n158\t    const fees = contracts * CONFIG.contractValue * CONFIG.tradingFeePct * 2; // entry + exit\n159\t    const netPnL = rawPnL - fees;\n160\t\n161\t    currentCapital += netPnL;\n162\t    peakCapital = Math.max(peakCapital, currentCapital);\n163\t\n164\t    const drawdown = peakCapital - currentCapital;\n165\t    if (drawdown > maxDrawdown) {\n166\t      maxDrawdown = drawdown;\n167\t      maxDrawdownPct = (drawdown / peakCapital) * 100;\n168\t    }\n169\t\n170\t    if (netPnL > 0) { wins++; totalWinAmt += netPnL; }\n171\t    else { losses++; totalLossAmt += Math.abs(netPnL); }\n172\t\n173\t    trades.push({\n174\t      signal: entry.id,\n175\t      pair: `${entry.market_a} / ${entry.market_b}`,\n176\t      contracts,\n177\t      z_score: entry.z_score,\n178\t      confidence: entry.confidence || 0,\n179\t      entrySpread: entryPrice.toFixed(4),\n180\t      exitSpread: exitPrice.toFixed(4),\n181\t      rawPnL: rawPnL.toFixed(2),\n182\t      fees: fees.toFixed(2),\n183\t      netPnL: netPnL.toFixed(2),\n184\t      capital: currentCapital.toFixed(2),\n185\t      drawdownPct: ((peakCapital - currentCapital) / peakCapital * 100).toFixed(2),\n186\t    });\n187\t  }\n188\t\n189\t  const totalTrades = wins + losses;\n190\t  return {\n191\t    label,\n192\t    startCapital: capital.toFixed(2),\n193\t    endCapital: currentCapital.toFixed(2),\n194\t    returnPct: (((currentCapital - capital) / capital) * 100).toFixed(2),\n195\t    totalTrades,\n196\t    wins,\n197\t    losses,\n198\t    winRate: totalTrades > 0 ? ((wins / totalTrades) * 100).toFixed(1) : '0.0',\n199\t    maxDrawdown: maxDrawdown.toFixed(2),\n200\t    maxDrawdownPct: maxDrawdownPct.toFixed(2),\n201\t    circuitBroken,\n202\t    trades,\n203\t  };\n204\t}\n205\t\n206\t// --- Main ---\n207\tfunction main() {\n208\t  console.log('=== Walk-Forward Validation + Position Sizing — T580 ===\\n');\n209\t  console.log(`Config: ${CONFIG.windowCount} windows, ${(CONFIG.trainRatio*100)}/${((1-CONFIG.trainRatio)*100)} train/test`);\n210\t  console.log(`Kelly: ${CONFIG.kellyFraction} fraction, ${(CONFIG.maxKellyBet*100)}% max bet`);\n211\t  console.log(`Slippage: ${CONFIG.slippageBps} bps, Fee: ${CONFIG.tradingFeePct*100}%`);\n212\t  console.log(`Circuit breaker: ${CONFIG.maxDrawdownPct}% max drawdown`);\n213\t  console.log(`Capital: $${CONFIG.initialCapital}\\n`);\n214\t\n215\t  const { signals } = loadSignals();\n216\t  const windows = walkForward(signals);\n217\t\n218\t  console.log(`Walk-forward: ${windows.length} rolling windows\\n`);\n219\t\n220\t  const results = [];\n221\t  let capital = CONFIG.initialCapital;\n222\t\n223\t  for (const w of windows) {\n224\t    const label = w.windowNum ? `Window ${w.windowNum}` : 'Single';\n225\t\n226\t    // Train phase: compute stats (no real trading)\n227\t    console.log(`--- ${label} TRAIN (${w.train.length} signals) ---`);\n228\t    const trainResult = simulateWindow(w.train, w.exits || [], capital, `${label} Train`);\n229\t    console.log(`  Win rate: ${trainResult.winRate}% | Return: ${trainResult.returnPct}% | Max DD: ${trainResult.maxDrawdownPct}%`);\n230\t\n231\t    // Test phase: trade with parameters learned from train\n232\t    console.log(`--- ${label} TEST (${w.test.length} signals) ---`);\n233\t    const testResult = simulateWindow(w.test, w.exits || [], capital, `${label} Test`);\n234\t    console.log(`  Win rate: ${testResult.winRate}% | Return: ${testResult.returnPct}% | Max DD: ${testResult.maxDrawdownPct}%`);\n235\t\n236\t    if (testResult.circuitBroken) {\n237\t      console.log(`  *** CIRCUIT BREAKER TRIGGERED at ${CONFIG.maxDrawdownPct}% drawdown ***`);\n238\t    }\n239\t\n240\t    capital = parseFloat(testResult.endCapital);\n241\t    results.push({ train: trainResult, test: testResult });\n242\t  }\n243\t\n244\t  // Summary\n245\t  console.log('\\n=== WALK-FORWARD SUMMARY ===');\n246\t  const allTestTrades = results.reduce((a, r) => a + r.test.totalTrades, 0);\n247\t  const allTestWins = results.reduce((a, r) => a + r.test.wins, 0);\n248\t  const finalCapital = parseFloat(results[results.length - 1].test.endCapital);\n249\t  const totalReturn = ((finalCapital - CONFIG.initialCapital) / CONFIG.initialCapital * 100).toFixed(2);\n250\t  const worstDD = Math.max(...results.map(r => parseFloat(r.test.maxDrawdownPct)));\n251\t  const anyCircuitBreak = results.some(r => r.test.circuitBroken);\n252\t\n253\t  console.log(`Total test trades: ${allTestTrades}`);\n254\t  console.log(`Overall win rate: ${allTestTrades > 0 ? ((allTestWins/allTestTrades)*100).toFixed(1) : 0}%`);\n255\t  console.log(`Final capital: $${finalCapital.toFixed(2)} (${totalReturn}% return)`);\n256\t  console.log(`Worst drawdown: ${worstDD.toFixed(2)}%`);\n257\t  console.log(`Circuit breaker triggered: ${anyCircuitBreak ? 'YES' : 'No'}`);\n258\t  console.log(`Slippage model: ${CONFIG.slippageBps} bps per trade`);\n259\t  console.log(`Position sizing: Quarter-Kelly, max ${CONFIG.maxKellyBet*100}% per trade`);\n260\t\n261\t  // Write output\n262\t  const output = {\n263\t    generated_at: new Date().toISOString(),\n264\t    task: 'T580',\n265\t    config: CONFIG,\n266\t    windows: results.map(r => ({ train: { ...r.train, trades: r.train.trades.length }, test: { ...r.test, trades: r.test.trades.length } })),\n267\t    summary: {\n268\t      totalTestTrades: allTestTrades,\n269\t      overallWinRate: allTestTrades > 0 ? parseFloat(((allTestWins/allTestTrades)*100).toFixed(1)) : 0,\n270\t      initialCapital: CONFIG.initialCapital,\n271\t      finalCapital: parseFloat(finalCapital.toFixed(2)),\n272\t      totalReturnPct: parseFloat(totalReturn),\n273\t      worstDrawdownPct: worstDD,\n274\t      circuitBreakerTriggered: anyCircuitBreak,\n275\t      slippageBps: CONFIG.slippageBps,\n276\t      positionSizing: 'quarter-kelly',\n277\t    },\n278\t    detailedTrades: results.flatMap(r => r.test.trades),\n279\t  };\n280\t\n281\t  const outPath = path.join(__dirname, 'walk_forward_results.json');\n282\t  fs.writeFileSync(outPath, JSON.stringify(output, null, 2));\n283\t  console.log(`\\nResults written to: ${outPath}`);\n284\t\n285\t  return output;\n286\t}\n287\t\n288\tmain();\n289\t"}]},"parent_tool_use_id":null,"session_id":"7405149f-ccdd-40fc-a568-54ece0530c63","uuid":"a400aab7-b56e-4471-af86-20164d0f61dc","timestamp":"2026-04-04T20:38:18.931Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/chenyangcui/Documents/code/aicompany/planets/kalshi-traders/output/alice/walk_forward_backtest.js","content":"#!/usr/bin/env node\n/**\n * Walk-Forward Validation + Position Sizing — T580\n *\n * Consumes Bob's signals.json (does NOT regenerate signals).\n * Adds:\n *   1. Rolling window walk-forward with train/test split\n *   2. Kelly criterion position sizing\n *   3. Slippage modeling (bid-ask spread impact)\n *   4. Max drawdown tracking with circuit breaker\n *\n * Run: node walk_forward_backtest.js\n * Author: Alice (Lead Coordinator) — picking up for idle Dave\n */\n\nconst fs = require('fs');\nconst path = require('path');\n\n// --- Configuration ---\nconst CONFIG = {\n  // Walk-forward\n  trainRatio: 0.6,          // 60% train, 40% test per window\n  windowCount: 3,           // number of rolling windows\n  // Kelly criterion\n  kellyFraction: 0.25,      // quarter-Kelly for safety\n  maxKellyBet: 0.10,        // max 10% of capital per trade\n  // Slippage\n  slippageBps: 50,          // 50 basis points slippage (bid-ask spread)\n  tradingFeePct: 0.01,      // 1% trading fee per side\n  // Risk management\n  maxDrawdownPct: 15,       // circuit breaker at 15% drawdown\n  initialCapital: 1000,     // $1000 starting capital\n  contractValue: 1,         // $1 per contract on Kalshi\n};\n\n// --- Load Signals ---\nfunction loadSignals() {\n  const signalPaths = [\n    path.join(__dirname, '..', 'bob', 'signals.json'),\n    path.join(__dirname, '..', '..', 'output', 'bob', 'signals.json'),\n  ];\n\n  for (const p of signalPaths) {\n    try {\n      const data = JSON.parse(fs.readFileSync(p, 'utf8'));\n      const signals = data.signals || data;\n      if (Array.isArray(signals) && signals.length > 0) {\n        console.log(`Loaded ${signals.length} signals from ${p}`);\n        return { signals, config: data.config || {} };\n      }\n    } catch {}\n  }\n\n  console.error('ERROR: Cannot find signals.json. This script consumes Bob\\'s signals — does NOT regenerate.');\n  process.exit(1);\n}\n\n// --- Kelly Criterion Position Sizing ---\nfunction kellySize(winRate, avgWin, avgLoss, capital) {\n  if (avgLoss === 0 || winRate === 0) return 0;\n  const b = avgWin / avgLoss;  // win/loss ratio\n  const q = 1 - winRate;\n  const kelly = (winRate * b - q) / b;\n\n  // Apply fraction and cap\n  const adjustedKelly = Math.max(0, kelly) * CONFIG.kellyFraction;\n  const maxBet = capital * CONFIG.maxKellyBet;\n  const betSize = Math.min(adjustedKelly * capital, maxBet);\n\n  return Math.max(0, Math.floor(betSize / CONFIG.contractValue));\n}\n\n// --- Slippage Model ---\nfunction applySlippage(price, direction) {\n  const slippage = CONFIG.slippageBps / 10000;\n  if (direction === 'BUY') return price * (1 + slippage);\n  return price * (1 - slippage);\n}\n\n// --- Walk-Forward Engine ---\nfunction walkForward(signals) {\n  const entrySignals = signals.filter(s => s.type === 'ENTRY');\n  const exitSignals = signals.filter(s => s.type === 'EXIT');\n\n  if (entrySignals.length < CONFIG.windowCount * 2) {\n    console.warn(`Only ${entrySignals.length} entry signals — using single window`);\n    return [{ train: entrySignals.slice(0, Math.floor(entrySignals.length * CONFIG.trainRatio)),\n              test: entrySignals.slice(Math.floor(entrySignals.length * CONFIG.trainRatio)),\n              exits: exitSignals }];\n  }\n\n  const windowSize = Math.floor(entrySignals.length / CONFIG.windowCount);\n  const windows = [];\n\n  for (let i = 0; i < CONFIG.windowCount; i++) {\n    const start = i * windowSize;\n    const end = Math.min(start + windowSize, entrySignals.length);\n    const window = entrySignals.slice(start, end);\n    const splitIdx = Math.floor(window.length * CONFIG.trainRatio);\n\n    windows.push({\n      windowNum: i + 1,\n      train: window.slice(0, splitIdx),\n      test: window.slice(splitIdx),\n      exits: exitSignals.filter(e => {\n        const eTime = new Date(e.timestamp).getTime();\n        const wStart = new Date(window[0].timestamp).getTime();\n        const wEnd = new Date(window[window.length - 1].timestamp).getTime();\n        return eTime >= wStart && eTime <= wEnd + 86400000;\n      }),\n    });\n  }\n\n  return windows;\n}\n\n// --- Simulate Trades in a Window ---\nfunction simulateWindow(entries, exits, capital, label) {\n  let currentCapital = capital;\n  let peakCapital = capital;\n  let maxDrawdown = 0;\n  let maxDrawdownPct = 0;\n  let circuitBroken = false;\n  const trades = [];\n\n  // Compute running stats for Kelly from prior trades\n  let wins = 0, losses = 0, totalWinAmt = 0, totalLossAmt = 0;\n\n  for (const entry of entries) {\n    // Circuit breaker check\n    const currentDrawdownPct = ((peakCapital - currentCapital) / peakCapital) * 100;\n    if (currentDrawdownPct >= CONFIG.maxDrawdownPct) {\n      circuitBroken = true;\n      break;\n    }\n\n    // Find matching exit\n    const exit = exits.find(e =>\n      (e.market_a === entry.market_a && e.market_b === entry.market_b) &&\n      new Date(e.timestamp) > new Date(entry.timestamp)\n    );\n\n    // Kelly position sizing\n    const winRate = (wins + losses) > 0 ? wins / (wins + losses) : 0.5;\n    const avgWin = wins > 0 ? totalWinAmt / wins : 0.05;\n    const avgLoss = losses > 0 ? totalLossAmt / losses : 0.03;\n    const contracts = kellySize(winRate, avgWin, avgLoss, currentCapital);\n\n    if (contracts === 0) continue;\n\n    // Compute P&L with slippage\n    const entrySpread = entry.spread || 0.05;\n    const exitSpread = exit ? (exit.spread || 0.03) : entrySpread * 0.9;\n\n    const entryPrice = applySlippage(entrySpread, 'BUY');\n    const exitPrice = applySlippage(exitSpread, 'SELL');\n    const rawPnL = (exitPrice - entryPrice) * contracts * 100; // cents to dollars\n    const fees = contracts * CONFIG.contractValue * CONFIG.tradingFeePct * 2; // entry + exit\n    const netPnL = rawPnL - fees;\n\n    currentCapital += netPnL;\n    peakCapital = Math.max(peakCapital, currentCapital);\n\n    const drawdown = peakCapital - currentCapital;\n    if (drawdown > maxDrawdown) {\n      maxDrawdown = drawdown;\n      maxDrawdownPct = (drawdown / peakCapital) * 100;\n    }\n\n    if (netPnL > 0) { wins++; totalWinAmt += netPnL; }\n    else { losses++; totalLossAmt += Math.abs(netPnL); }\n\n    trades.push({\n      signal: entry.id,\n      pair: `${entry.market_a} / ${entry.market_b}`,\n      contracts,\n      z_score: entry.z_score,\n      confidence: entry.confidence || 0,\n      entrySpread: entryPrice.toFixed(4),\n      exitSpread: exitPrice.toFixed(4),\n      rawPnL: rawPnL.toFixed(2),\n      fees: fees.toFixed(2),\n      netPnL: netPnL.toFixed(2),\n      capital: currentCapital.toFixed(2),\n      drawdownPct: ((peakCapital - currentCapital) / peakCapital * 100).toFixed(2),\n    });\n  }\n\n  const totalTrades = wins + losses;\n  return {\n    label,\n    startCapital: capital.toFixed(2),\n    endCapital: currentCapital.toFixed(2),\n    returnPct: (((currentCapital - capital) / capital) * 100).toFixed(2),\n    totalTrades,\n    wins,\n    losses,\n    winRate: totalTrades > 0 ? ((wins / totalTrades) * 100).toFixed(1) : '0.0',\n    maxDrawdown: maxDrawdown.toFixed(2),\n    maxDrawdownPct: maxDrawdownPct.toFixed(2),\n    circuitBroken,\n    trades,\n  };\n}\n\n// --- Main ---\nfunction main() {\n  console.log('=== Walk-Forward Validation + Position Sizing — T580 ===\\n');\n  console.log(`Config: ${CONFIG.windowCount} windows, ${(CONFIG.trainRatio*100)}/${((1-CONFIG.trainRatio)*100)} train/test`);\n  console.log(`Kelly: ${CONFIG.kellyFraction} fraction, ${(CONFIG.maxKellyBet*100)}% max bet`);\n  console.log(`Slippage: ${CONFIG.slippageBps} bps, Fee: ${CONFIG.tradingFeePct*100}%`);\n  console.log(`Circuit breaker: ${CONFIG.maxDrawdownPct}% max drawdown`);\n  console.log(`Capital: $${CONFIG.initialCapital}\\n`);\n\n  const { signals } = loadSignals();\n  const windows = walkForward(signals);\n\n  console.log(`Walk-forward: ${windows.length} rolling windows\\n`);\n\n  const results = [];\n  let capital = CONFIG.initialCapital;\n\n  for (const w of windows) {\n    const label = w.windowNum ? `Window ${w.windowNum}` : 'Single';\n\n    // Train phase: compute stats (no real trading)\n    console.log(`--- ${label} TRAIN (${w.train.length} signals) ---`);\n    const trainResult = simulateWindow(w.train, w.exits || [], capital, `${label} Train`);\n    console.log(`  Win rate: ${trainResult.winRate}% | Return: ${trainResult.returnPct}% | Max DD: ${trainResult.maxDrawdownPct}%`);\n\n    // Test phase: trade with parameters learned from train\n    console.log(`--- ${label} TEST (${w.test.length} signals) ---`);\n    const testResult = simulateWindow(w.test, w.exits || [], capital, `${label} Test`);\n    console.log(`  Win rate: ${testResult.winRate}% | Return: ${testResult.returnPct}% | Max DD: ${testResult.maxDrawdownPct}%`);\n\n    if (testResult.circuitBroken) {\n      console.log(`  *** CIRCUIT BREAKER TRIGGERED at ${CONFIG.maxDrawdownPct}% drawdown ***`);\n    }\n\n    capital = parseFloat(testResult.endCapital);\n    results.push({ train: trainResult, test: testResult });\n  }\n\n  // Summary\n  console.log('\\n=== WALK-FORWARD SUMMARY ===');\n  const allTestTrades = results.reduce((a, r) => a + r.test.totalTrades, 0);\n  const allTestWins = results.reduce((a, r) => a + r.test.wins, 0);\n  const finalCapital = parseFloat(results[results.length - 1].test.endCapital);\n  const totalReturn = ((finalCapital - CONFIG.initialCapital) / CONFIG.initialCapital * 100).toFixed(2);\n  const worstDD = Math.max(...results.map(r => parseFloat(r.test.maxDrawdownPct)));\n  const anyCircuitBreak = results.some(r => r.test.circuitBroken);\n\n  console.log(`Total test trades: ${allTestTrades}`);\n  console.log(`Overall win rate: ${allTestTrades > 0 ? ((allTestWins/allTestTrades)*100).toFixed(1) : 0}%`);\n  console.log(`Final capital: $${finalCapital.toFixed(2)} (${totalReturn}% return)`);\n  console.log(`Worst drawdown: ${worstDD.toFixed(2)}%`);\n  console.log(`Circuit breaker triggered: ${anyCircuitBreak ? 'YES' : 'No'}`);\n  console.log(`Slippage model: ${CONFIG.slippageBps} bps per trade`);\n  console.log(`Position sizing: Quarter-Kelly, max ${CONFIG.maxKellyBet*100}% per trade`);\n\n  // Write output\n  const output = {\n    generated_at: new Date().toISOString(),\n    task: 'T580',\n    config: CONFIG,\n    windows: results.map(r => ({ train: { ...r.train, trades: r.train.trades.length }, test: { ...r.test, trades: r.test.trades.length } })),\n    summary: {\n      totalTestTrades: allTestTrades,\n      overallWinRate: allTestTrades > 0 ? parseFloat(((allTestWins/allTestTrades)*100).toFixed(1)) : 0,\n      initialCapital: CONFIG.initialCapital,\n      finalCapital: parseFloat(finalCapital.toFixed(2)),\n      totalReturnPct: parseFloat(totalReturn),\n      worstDrawdownPct: worstDD,\n      circuitBreakerTriggered: anyCircuitBreak,\n      slippageBps: CONFIG.slippageBps,\n      positionSizing: 'quarter-kelly',\n    },\n    detailedTrades: results.flatMap(r => r.test.trades),\n  };\n\n  const outPath = path.join(__dirname, 'walk_forward_results.json');\n  fs.writeFileSync(outPath, JSON.stringify(output, null, 2));\n  console.log(`\\nResults written to: ${outPath}`);\n\n  return output;\n}\n\nmain();\n","numLines":289,"startLine":1,"totalLines":289}}}
