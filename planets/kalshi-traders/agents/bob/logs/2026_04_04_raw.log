al,\n315\t      final_capital: parseFloat(capital.toFixed(2)),\n316\t      total_pnl: parseFloat(totalPnl.toFixed(4)),\n317\t      total_fees: parseFloat(totalFees.toFixed(4)),\n318\t      total_trades: trades.length,\n319\t      wins,\n320\t      losses,\n321\t      win_rate: trades.length > 0 ? parseFloat((wins / trades.length).toFixed(4)) : 0,\n322\t      avg_pnl_per_trade: trades.length > 0 ? parseFloat((totalPnl / trades.length).toFixed(4)) : 0,\n323\t      max_drawdown_pct: parseFloat(maxDrawdown.toFixed(2)),\n324\t      sharpe_estimate: estimateSharpe(trades),\n325\t    },\n326\t  };\n327\t}\n328\t\n329\tfunction estimateSharpe(trades) {\n330\t  if (trades.length < 2) return 0;\n331\t  const returns = trades.map(t => t.pnl_dollars);\n332\t  const mean = returns.reduce((a, b) => a + b, 0) / returns.length;\n333\t  const variance = returns.reduce((s, r) => s + (r - mean) ** 2, 0) / (returns.length - 1);\n334\t  const std = Math.sqrt(variance) || 0.001;\n335\t  // Annualize assuming ~252 trading days, ~2 trades/day\n336\t  const annualFactor = Math.sqrt(252 * 2);\n337\t  return parseFloat(((mean / std) * annualFactor).toFixed(2));\n338\t}\n339\t\n340\t// ---------------------------------------------------------------------------\n341\t// Price Data Generator (uses same seeded approach as run_pipeline.js)\n342\t// ---------------------------------------------------------------------------\n343\tfunction generatePriceData(correlationPairs) {\n344\t  const priceData = {};\n345\t  const allTickers = new Set();\n346\t\n347\t  for (const pair of (correlationPairs.pairs || [])) {\n348\t    allTickers.add(pair.market_a);\n349\t    allTickers.add(pair.market_b);\n350\t  }\n351\t\n352\t  // Shared market factors for correlated price generation\n353\t  const marketFactors = {};\n354\t  function getMarketFactor(category) {\n355\t    if (marketFactors[category]) return marketFactors[category];\n356\t    const seed = category.split(\"\").reduce((a, c) => a + c.charCodeAt(0), 