{"type": "item.started", "item": {"id": "item_27", "type": "command_execution", "command": "/bin/zsh -lc \"node - <<'NODE'\nconst http = require('http');\nconst agents = ['alice','bob','charlie','dave','eve','frank','grace','heidi','ivan','judy','karl','liam','mia','nick','olivia','pat','quinn','rosa','sam','tina'];\nfunction get(path){return new Promise((resolve,reject)=>{http.get({host:'localhost',port:3199,path},res=>{let d='';res.on('data',c=>d+=c);res.on('end',()=>{try{resolve(JSON.parse(d))}catch(e){reject(new Error(path+' '+d.slice(0,200)))}})}).on('error',reject)})}\n(async()=>{\n const cost = await get('/api/cost');\n const rows = [];\n for (const agent of agents){\n   const data = await get(\"'`/api/agents/${agent}/cycles`);\n   const cycles = data.cycles || [];\n   const completed = cycles.filter(c => c.ended).length;\n   const active = cycles.filter(c => !c.ended).length;\n   const actions = cycles.reduce((n,c)=>n+(c.action_count||0),0);\n   const latest = cycles[0]?.n ?? null;\n   rows.push({agent, today_cycles: cost.per_agent.find(p=>p.name===agent)?.today_cycles ?? 0, completed, active, actions, latest});\n }\n console.log(JSON.stringify({today_cycles: cost.today_cycles, total_7d_cycles: cost.total_7d_cycles, total_7d_usd: cost.total_7d_usd, rows}, null, 2));\n})();\nNODE'", "aggregated_output": "", "exit_code": null, "status": "in_progress"}}
