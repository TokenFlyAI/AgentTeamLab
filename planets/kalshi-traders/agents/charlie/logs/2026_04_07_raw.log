solid #ef4444; }\n        .refresh-btn {\n            background: #334155;\n            color: #e2e8f0;\n            border: 1px solid #475569;\n            padding: 0.5rem 1rem;\n            border-radius: 6px;\n            cursor: pointer;\n            font-size: 0.875rem;\n            transition: all 0.2s;\n        }\n        .refresh-btn:hover { background: #475569; }\n        .refresh-btn:focus { outline: 2px solid #22c55e; outline-offset: 2px; }\n\n        .container { padding: 1.5rem; max-width: 1200px; margin: 0 auto; }\n\n        /* Pipeline Flow */\n        .pipeline-flow {\n            display: flex;\n            align-items: flex-start;\n            gap: 0;\n            margin-bottom: 2rem;\n            overflow-x: auto;\n            padding: 1rem 0;\n        }\n        .phase-card {\n            flex: 1;\n            min-width: 200px;\n            background: #1e293b;\n            border-radius: 12px;\n            border: 2px solid #334155;\n            overflow: hidden;\n            transition: border-color 0.3s;\n        }\n        .phase-card.complete { border-color: #22c55e; }\n        .phase-card.incomplete { border-color: #f59e0b; }\n        .phase-card.error { border-color: #ef4444; }\n        .phase-card.unknown { border-color: #64748b; }\n        .phase-header {\n            padding: 0.75rem 1rem;\n            font-weight: 600;\n            font-size: 0.875rem;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n        }\n        .phase-card.complete .phase-header { background: #22c55e22; color: #22c55e; }\n        .phase-card.incomplete .phase-header { background: #f59e0b22; color: #f59e0b; }\n        .phase-card.error .phase-header { background: #ef444422; color: #ef4444; }\n        .phase-card.unknown .phase-header { background: #64748b22; color: #64748b; }\n        .phase-body {\n            padding: 1rem;\n        }\n        .phase-stat {\n            display: flex;\n            justify-content: space-between;\n            padding: 0.25rem 0;\n            font-size: 0.8125rem;\n            color: #94a3b8;\n        }\n        .phase-stat span:last-child { color: #e2e8f0; font-weight: 500; font-variant-numeric: tabular-nums; }\n        .phase-owner {\n            margin-top: 0.5rem;\n            padding-top: 0.5rem;\n            border-top: 1px solid #334155;\n            font-size: 0.75rem;\n            color: #64748b;\n        }\n        .arrow {\n            display: flex;\n            align-items: center;\n            padding: 0 0.5rem;\n            color: #475569;\n            font-size: 1.5rem;\n            flex-shrink: 0;\n            margin-top: 2rem;\n        }\n        .arrow.active { color: #22c55e; }\n\n        /* Blocker Banner */\n        .blocker-banner {\n            background: #ef444411;\n            border: 1px solid #ef4444;\n            border-radius: 8px;\n            padding: 1rem 1.25rem;\n            margin-bottom: 1.5rem;\n        }\n        .blocker-banner h3 {\n            color: #ef4444;\n            font-size: 0.9375rem;\n            margin-bottom: 0.5rem;\n        }\n        .blocker-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n            padding: 0.25rem 0;\n            font-size: 0.8125rem;\n            color: #fca5a5;\n        }\n        .blocker-badge {\n            background: #ef444433;\n            color: #ef4444;\n            padding: 0.125rem 0.5rem;\n            border-radius: 4px;\n            font-weight: 600;\n            font-size: 0.75rem;\n            flex-shrink: 0;\n        }\n        .no-blockers {\n            background: #22c55e11;\n            border: 1px solid #22c55e33;\n            border-radius: 8px;\n            padding: 1rem 1.25rem;\n            margin-bottom: 1.5rem;\n            color: #86efac;\n            font-size: 0.875rem;\n        }\n\n        /* Data Grid */\n        .grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }\n        @media (min-width: 768px) { .grid { grid-template-columns: repeat(2, 1fr); } }\n        .panel {\n            background: #1e293b;\n            border-radius: 12px;\n            border: 1px solid #334155;\n            overflow: hidden;\n        }\n        .panel-header {\n            background: #334155;\n            padding: 0.75rem 1rem;\n            font-weight: 600;\n            font-size: 0.9375rem;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n        }\n        .panel-badge {\n            background: #22c55e33;\n            color: #22c55e;\n            padding: 0.125rem 0.5rem;\n            border-radius: 4px;\n            font-size: 0.75rem;\n            font-weight: 600;\n        }\n        .panel-content {\n            padding: 1rem;\n            max-height: 400px;\n            overflow-y: auto;\n        }\n        table {\n            width: 100%;\n            border-collapse: collapse;\n            font-size: 0.8125rem;\n        }\n        th {\n            text-align: left;\n            color: #64748b;\n            font-weight: 500;\n            padding: 0.5rem 0.75rem;\n            border-bottom: 1px solid #334155;\n            position: sticky;\n            top: 0;\n            background: #1e293b;\n        }\n        td {\n","exit_code":0,"status":"completed"}}
