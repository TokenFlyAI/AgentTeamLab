 .tab-content.active { display: block; }\n        \n        .grid {\n            display: grid;\n            grid-template-columns: 1fr;\n            gap: 1rem;\n        }\n        \n        @media (min-width: 768px) {\n            .grid { grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }\n            .container { padding: 1.5rem; }\n            .header { padding: 1rem 2rem; }\n            .header h1 { font-size: 1.5rem; }\n        }\n        \n        @media (min-width: 1280px) {\n            .grid { grid-template-columns: repeat(2, 1fr); }\n        }\n        \n        .panel {\n            background: #1e293b;\n            border-radius: 12px;\n            border: 1px solid #334155;\n            overflow: hidden;\n            display: flex;\n            flex-direction: column;\n        }\n        \n        .panel-header {\n            background: #334155;\n            padding: 0.875rem 1rem;\n            font-weight: 600;\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            font-size: 0.9375rem;\n        }\n        \n        .panel-content {\n            padding: 1rem;\n            flex: 1;\n            min-height: 200px;\n            max-height: 450px;\n            overflow-y: auto;\n        }\n        \n        .panel-content.chart-container { max-height: 320px; position: relative; }\n        \n        /* Status Page Styles */\n        .status-banner {\n            padding: 1.5rem;\n            border-radius: 12px;\n            margin-bottom: 1.5rem;\n            display: flex;\n            align-items: center;\n            gap: 1rem;\n        }\n        \n        .status-banner.waiting {\n            background: linear-gradient(135deg, #f59e0b22 0%, #d9770622 100%);\n            border: 1px solid #f59e0b;\n        }\n        \n        .status-banner.ready {\n            background: linear-gradient(135deg, #22c55e22 0%, #16a34a22 100%);\n            border: 1px solid #22c55e;\n        }\n        \n        .status-banner.error {\n            background: linear-gradient(135deg, #ef444422 0%, #dc262622 100%);\n            border: 1px solid #ef4444;\n        }\n        \n        .status-icon { font-size: 2rem; }\n        .status-banner.waiting .status-icon { color: #f59e0b; }\n        .status-banner.ready .status-icon { color: #22c55e; }\n        .status-banner.error .status-icon { color: #ef4444; }\n        \n        .status-text h2 {\n            font-size: 1.25rem;\n            margin-bottom: 0.25rem;\n        }\n        \n        .status-banner.waiting h2 { color: #f59e0b; }\n        .status-banner.ready h2 { color: #22c55e; }\n        .status-banner.error h2 { color: #ef4444; }\n        \n        .status-text p {\n            color: #94a3b8;\n            font-size: 0.875rem;\n        }\n        \n        .setup-instructions {\n            background: #0f172a;\n            border-radius: 8px;\n            padding: 1rem;\n            margin-top: 1rem;\n        }\n        \n        .setup-instructions h3 {\n            font-size: 0.875rem;\n            color: #e2e8f0;\n            margin-bottom: 0.75rem;\n        }\n        \n        .setup-instructions ol {\n            margin-left: 1.25rem;\n            color: #94a3b8;\n            font-size: 0.875rem;\n        }\n        \n        .setup-instructions li { margin-bottom: 0.5rem; }\n        \n        .setup-instructions code {\n            background: #334155;\n            padding: 0.125rem 0.375rem;\n            border-radius: 4px;\n            font-family: monospace;\n            color: #22c55e;\n        }\n        \n        .metric-grid {\n            display: grid;\n            grid-template-columns: repeat(2, 1fr);\n            gap: 1rem;\n        }\n        \n        @media (min-width: 768px) {\n            .metric-grid { grid-template-columns: repeat(4, 1fr); }\n        }\n        \n","exit_code":0,"status":"completed"}}
