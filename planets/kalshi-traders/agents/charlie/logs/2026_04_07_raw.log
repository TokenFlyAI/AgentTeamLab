\n  .refresh-info { color: var(--text-dim); font-size: 0.75rem; position: absolute; top: 24px; right: 24px; }\n\n  /* Handoff Chain */\n  .chain-section { margin-bottom: 32px; }\n  .section-title { font-size: 1.1rem; margin-bottom: 16px; color: var(--accent); border-bottom: 1px solid var(--border); padding-bottom: 8px; }\n  .chain {\n    display: flex;\n    align-items: center;\n    gap: 0;\n    overflow-x: auto;\n    padding: 16px 0;\n  }\n  .chain-node {\n    background: var(--surface);\n    border: 2px solid var(--border);\n    border-radius: 12px;\n    padding: 16px 20px;\n    min-width: 180px;\n    text-align: center;\n    position: relative;\n    transition: border-color 0.3s;\n  }\n  .chain-node.done { border-color: var(--green); }\n  .chain-node.in_progress, .chain-node.in_review { border-color: var(--yellow); }\n  .chain-node.open { border-color: var(--border); }\n  .chain-node.blocked { border-color: var(--red); }\n\n  .chain-arrow {\n    display: flex;\n    align-items: center;\n    padding: 0 8px;\n    color: var(--text-dim);\n    font-size: 1.5rem;\n    flex-shrink: 0;\n  }\n  .chain-arrow.complete { color: var(--green); }\n\n  .node-agent { font-weight: 600; font-size: 1rem; margin-bottom: 4px; }\n  .node-task { font-size: 0.8rem; color: var(--text-dim); margin-bottom: 8px; }\n  .node-title { font-size: 0.75rem; color: var(--text-dim); margin-bottom: 8px; line-height: 1.3; }\n\n  .status-badge {\n    display: inline-block;\n    padding: 2px 10px;\n    border-radius: 12px;\n    font-size: 0.7rem;\n    font-weight: 600;\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n  }\n  .status-badge.done { background: rgba(63,185,80,0.15); color: var(--green); }\n  .status-badge.in_progress { background: rgba(210,153,34,0.15); color: var(--yellow); }\n  .status-badge.in_review { background: rgba(188,140,255,0.15); color: var(--purple); }\n  .status-badge.open { background: rgba(139,148,158,0.15); color: var(--text-dim); }\n  .status-badge.blocked { background: rgba(248,81,73,0.15); color: var(--red); }\n\n  /* Parallel Tasks Grid */\n  .parallel-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));\n    gap: 12px;\n    margin-top: 12px;\n  }\n  .parallel-card {\n    background: var(--surface);\n    border: 1px solid var(--border);\n    border-radius: 8px;\n    padding: 14px;\n    border-left: 3px solid var(--border);\n  }\n  .parallel-card.done { border-left-color: var(--green); }\n  .parallel-card.in_progress { border-left-color: var(--yellow); }\n  .parallel-card.in_review { border-left-color: var(--purple); }\n  .parallel-card.open { border-left-color: var(--text-dim); }\n\n  .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }\n  .card-agent { font-weight: 600; font-size: 0.9rem; }\n  .card-task { font-size: 0.75rem; color: var(--text-dim); }\n  .card-title { font-size: 0.8rem; color: var(--text-dim); line-height: 1.3; }\n\n  /* Summary Bar */\n  .summary {\n    display: flex;\n    gap: 16px;\n    margin-bottom: 24px;\n    flex-wrap: wrap;\n  }\n  .summary-item {\n    background: var(--surface);\n    border: 1px solid var(--border);\n    border-radius: 8px;\n    padding: 12px 20px;\n    text-align: center;\n    min-width: 100px;\n  }\n  .summary-value { font-size: 1.5rem; font-weight: 700; }\n  .summary-label { font-size: 0.7rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.5px; }\n  .summary-value.green { color: var(--green); }\n  .summary-value.yellow { color: var(--yellow); }\n  .summary-value.blue { color: var(--accent); }\n\n  /* Handoff Log */\n  .handoff-log { margin-top: 16px; }\n  .log-entry {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    padding: 8px 0;\n    border-bottom: 1px solid var(--border);\n    font-size: 0.8rem;\n  }\n  .log-icon { font-size: 1rem; }\n  .log-text { color: var(--text-dim); }\n  .log-text strong { color: var(--text); }\n\n  @media (max-width: 768px) {\n    body { padding: 12px; }\n    .chain { flex-direction: column; align-items: stretch; }\n    .chain-arrow { transform: rotate(90deg); justify-content: center; padding: 4px 0; }\n    .parallel-grid { grid-template-columns: 1fr; }\n  }\n</style>\n</head>\n<body>\n  <h1>Sprint 3 — Progress Tracker</h1>\n  <p class=\"subtitle\">Production Quality via Collaboration (D6) — Handoff Chain Visualization</p>\n  <div class=\"refresh-info\" id=\"refresh-info\">Auto-refresh: 15s</div>\n\n  <div class=\"summary\" id=\"summary\"></div>\n\n  <div class=\"chain-section\">\n    <div class=\"section-title\">Critical Path — Handoff Chain</div>\n    <div class=\"chain\" id=\"chain\"></div>\n    <div class=\"handoff-log\" id=\"handoff-log\"></div>\n  </div>\n\n  <div class=\"chain-section\">\n    <div class=\"section-title\">Parallel Tasks</div>\n    <div class=\"parallel-grid\" id=\"parallel\"></div>\n  </div>\n\n<script>\nconst CHAIN_TASKS = [\n  { id: 567, agent: 'Bob', role: 'Signals', handsOffTo: 'Dave' },\n  { id: 568, agent: 'Dave', role: 'Backtest', handsOffTo: 'Tina' },\n  { id: 570, agent: 'Tina', role: 'QA', handsOffTo: 'Olivia' },\n  { id: 572, agent: 'Olivia', role: 'Review', handsOffTo: null },\n];\n\nconst PARALLEL_TASKS = [569, 571, 573, 574, 575, 576];\n\nconst API_BASE = window.location.port === ''\n  ? ''\n  : `${window.location.protocol}//${window.location.hostname}:3199`;\n\nfunction statusClass(s) {\n  if (!s) return 'open';\n  return s.replace(/\\s+/g, '_').toLowerCase();\n}\n\nfunction statusLabel(s) {\n  if (!s) return 'OPEN';\n  return s.toUpperCase().replace(/_/g, ' ');\n}\n\nfunction isComplete(s) {\n  return s === 'done' || s === 'in_review';\n}\n\nfunction buildSummary(tasks) {\n  const sprint3 = tasks.filter(t => CHAIN_TASKS.some(c => c.id === t.id) || PARALLEL_TASKS.includes(t.id));\n  const done = sprint3.filter(t => t.status === 'done').length;\n  const inProgress = sprint3.filter(t => t.status === 'in_progress').length;\n  const inReview = sprint3.filter(t => t.status === 'in_review').length;\n  const total = sprint3.length;\n\n  const chainComplete = CHAIN_TASKS.filter(c => {\n    const t = tasks.find(t => t.id === c.id);\n    return t && (t.status === 'done' || t.status === 'in_review');\n  }).length;\n\n  document.getElementById('summary').innerHTML = `\n    <div class=\"summary-item\"><div class=\"summary-value green\">${done}</div><div class=\"summary-label\">Done</div></div>\n    <div class=\"summary-item\"><div class=\"summary-value yellow\">${inReview}</div><div class=\"summary-label\">In Review</div></div>\n    <div class=\"summary-item\"><div class=\"summary-value yellow\">${inProgress}</div><div class=\"summary-label\">In Progress</div></div>\n    <div class=\"summary-item\"><div class=\"summary-value blue\">${total}</div><div class=\"summary-label\">Total Tasks</div></div>\n    <div class=\"summary-item\"><div class=\"summary-value ${chainComplete === CHAIN_TASKS.length ? 'green' : 'yellow'}\">${chainComplete}/${CHAIN_TASKS.length}</div><div class=\"summary-label\">Chain Steps Done</div></div>\n  `;\n}\n\n","exit_code":0,"status":"completed"}}
