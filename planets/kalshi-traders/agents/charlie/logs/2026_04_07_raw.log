ns {\n      margin-top: 14px;\n      display: grid;\n      gap: 10px;\n    }\n\n    .action {\n      padding: 12px;\n      border-radius: 16px;\n      background: rgba(23, 33, 33, 0.05);\n      border: 1px solid rgba(23, 33, 33, 0.08);\n    }\n\n    .action-title {\n      font-family: \"Courier New\", monospace;\n      font-size: 0.73rem;\n      text-transform: uppercase;\n      letter-spacing: 0.08em;\n      color: var(--muted);\n      margin-bottom: 6px;\n    }\n\n    .empty {\n      padding: 16px 20px 22px;\n      color: var(--ok);\n      font-size: 0.95rem;\n    }\n\n    .footer-note {\n      margin-top: 16px;\n      color: var(--muted);\n      font-size: 0.88rem;\n      line-height: 1.5;\n    }\n\n    @media (max-width: 980px) {\n      .summary,\n      .lanes,\n      .board {\n        grid-template-columns: 1fr;\n      }\n    }\n\n    @media (max-width: 640px) {\n      .shell { padding: 14px; }\n      .hero { padding: 20px; border-radius: 22px; }\n      .lane-grid { grid-template-columns: 1fr; }\n      .lane-top { flex-direction: column; }\n      .badge-stack { justify-content: start; }\n    }\n  </style>\n</head>\n<body>\n  <main class=\"shell\">\n    <section class=\"hero\">\n      <p class=\"eyebrow\">Sprint 6 / Real-Data Readiness</p>\n      <h1>Keep the board honest while T236 blocks live data.</h1>\n      <p class=\"hero-copy\">\n        This view is coordination-first: artifact paths, run commands, freshness, and the exact places where readiness claims still break down.\n      </p>\n      <div class=\"hero-meta\">\n        <span class=\"meta-chip\" id=\"generated-at\">Snapshot loading</span>\n        <span class=\"meta-chip\" id=\"api-state\">Credential state loading</span>\n      </div>\n    </section>\n\n    <section class=\"summary\" id=\"summary\"></section>\n\n    <section class=\"board\">\n      <article class=\"panel\">\n        <div class=\"panel-head\">\n          <h2 class=\"panel-title\">Blocking Signals</h2>\n          <p class=\"panel-subtitle\">Red means no-go, amber means review friction or stale evidence.</p>\n        </div>\n        <div class=\"blockers\" id=\"blockers\"></div>\n      </article>\n\n      <article class=\"panel\">\n        <div class=\"panel-head\">\n          <h2 class=\"panel-title\">Fast Commands</h2>\n          <p class=\"panel-subtitle\">Open the dashboard, inspect the JSON snapshot, or re-run the local server.</p>\n        </div>\n        <div class=\"command-list\">\n          <div class=\"command\">\n            <strong>Run</strong>\n            <code>node /Users/chenyangcui/Documents/code/aicompany/planets/kalshi-traders/output/charlie/serve_sprint6_readiness_dashboard.js --port 3461</code>\n          </div>\n          <div class=\"command\">\n            <strong>Verify</strong>\n            <code>curl -s http://localhost:3461/api/readiness | python3 -m json.tool</code>\n          </div>\n          <div class=\"command\">\n            <strong>Open</strong>\n            <span class=\"mono\">http://localhost:3461</span>\n          </div>\n        </div>\n      </article>\n    </section>\n\n    <section class=\"lanes\" id=\"lanes\"></section>\n    <p class=\"footer-note\">Status source: local task API on port 3199 plus direct artifact inspection. Missing task lookups are shown instead of hidden.</p>\n  </main>\n\n  <script>\n    function escapeHtml(value) {\n      return String(value ?? \"\")\n        .replace(/&/g, \"&amp;\")\n        .replace(/</g, \"&lt;\")\n        .replace(/>/g, \"&gt;\")\n        .replace(/\"/g, \"&quot;\")\n        .replace(/'/g, \"&#39;\");\n    }\n\n    function humanizeStatus(status) {\n      return String(status || \"unknown\").replace(/_/g, \" \");\n    }\n\n    function renderSummary(data) {\n      const items = [\n        [\"Artifacts Ready\", data.board.readyCount],\n        [\"In Review\", data.board.reviewCount],\n        [\"In Progress\", data.board.inProgressCount],\n        [\"Blockers\", data.board.blockerCount],\n      ];\n\n      document.getElementById(\"summary\").innerHTML = items.map(([label, value]) => `\n        <article class=\"tile\">\n          <div class=\"tile-label\">${escapeHtml(label)}</div>\n          <div class=\"tile-value\">${escapeHtml(value)}</div>\n        </article>\n      `).join(\"\");\n    }\n\n    function renderBlockers(blockers) {\n      const root = document.getElementById(\"blockers\");\n      if (!blockers.length) {\n        root.innerHTML = '<div class=\"empty\">No blockers detected in the current snapshot.</div>';\n        return;\n      }\n\n      root.innerHTML = blockers.map((blocker) => `\n        <article class=\"blocker ${escapeHtml(blocker.level)}\">\n          <h3>${escapeHtml(blocker.title)}</h3>\n          <p>${escapeHtml(blocker.message)}</p>\n        </article>\n      `).join(\"\");\n    }\n\n    function renderLanes(lanes) {\n      document.getElementById(\"lanes\").innerHTML = lanes.map((lane) => `\n        <article class=\"lane ${escapeHtml(lane.artifactState)}\">\n          <div class=\"lane-top\">\n            <div>\n              <div class=\"lane-kicker\">T${escapeHtml(lane.id)} / ${escapeHtml(lane.owner)} / ${escapeHtml(lane.label)}</div>\n              <h2>${escapeHtml(lane.title)}</h2>\n            </div>\n            <div class=\"badge-stack\">\n              <span class=\"badge ${escapeHtml(lane.artifactState)}\">${escapeHtml(humanizeStatus(lane.artifactState))}</span>\n              <span class=\"badge\">${escapeHtml(humanizeStatus(lane.taskStatus))}</span>\n            </div>\n          </div>\n\n          <div class=\"lane-grid\">\n            <div class=\"fact\">\n              <span class=\"fact-label\">Artifact</span>\n              <span class=\"fact-value path\">${escapeHtml(lane.artifact.path)}</span>\n            </div>\n            <div class=\"fact\">\n              <span class=\"fact-label\">Freshness</span>\n              <span class=\"fact-value mono\">${escapeHtml(lane.freshness || \"missing\")}</span>\n            </div>\n            <div class=\"fact\">\n              <span class=\"fact-label\">Task Lookup</span>\n              <span class=\"fact-value\">${lane.taskFound ? \"present on board API\" : \"missing on board API\"}</span>\n            </div>\n            <div class=\"fact\">\n              <span class=\"fact-label\">Artifact Size</span>\n              <span class=\"fact-value mono\">${lane.artifact.exists ? escapeHtml(lane.artifact.size + \" bytes\") : \"missing\"}</span>\n            </div>\n          </div>\n\n          <ul class=\"lane-list\">\n            ${lane.details.map((detail) => `<li>${escapeHtml(detail)}</li>`).join(\"\")}\n          </ul>\n","exit_code":0,"status":"completed"}}
