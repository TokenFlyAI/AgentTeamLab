{"type":"item.completed","item":{"id":"item_28","type":"command_execution","command":"/bin/zsh -lc \"sed -n '520,760p' ../../output/charlie/sprint6_readiness_dashboard.html\"","aggregated_output":"          </ul>\n\n          <div class=\"lane-actions\">\n            <div class=\"action\">\n              <div class=\"action-title\">Run</div>\n              <div class=\"mono\">${escapeHtml(lane.runCommand)}</div>\n            </div>\n            <div class=\"action\">\n              <div class=\"action-title\">Verify</div>\n              <div class=\"mono\">${escapeHtml(lane.verifyCommand)}</div>\n            </div>\n          </div>\n        </article>\n      `).join(\"\");\n    }\n\n    async function load() {\n      const response = await fetch(\"/api/readiness\");\n      const data = await response.json();\n\n      if (data.error) {\n        throw new Error(data.error);\n      }\n\n      document.getElementById(\"generated-at\").textContent = `Snapshot ${data.generatedAt}`;\n      document.getElementById(\"api-state\").textContent = data.apiKeyConfigured\n        ? \"KALSHI_API_KEY present\"\n        : \"KALSHI_API_KEY missing\";\n\n      renderSummary(data);\n      renderBlockers(data.blockers);\n      renderLanes(data.lanes);\n    }\n\n    load().catch((error) => {\n      document.getElementById(\"blockers\").innerHTML = `\n        <article class=\"blocker\">\n          <h3>Dashboard load failed</h3>\n          <p>${escapeHtml(error.message)}</p>\n        </article>\n      `;\n    });\n  </script>\n</body>\n</html>\n","exit_code":0,"status":"completed"}}
