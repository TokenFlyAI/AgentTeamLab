{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01A9pnud9AX12H6WWTc8vVKB","type":"tool_result","content":"1\t/**\n2\t * Kalshi REST API Client Module\n3\t *\n4\t * Supports real Kalshi API v2 (trading-api.kalshi.com) and mock mode for testing.\n5\t * Set KALSHI_API_KEY env var for real mode. Without it, falls back to mock mode.\n6\t *\n7\t * Usage:\n8\t *   const { KalshiClient } = require('./kalshi_client');\n9\t *   const client = new KalshiClient(); // auto-detects mock vs real\n10\t *   await client.login();\n11\t *   const markets = await client.getMarkets({ status: 'open', limit: 50 });\n12\t */\n13\t\n14\tconst https = require('https');\n15\tconst crypto = require('crypto');\n16\t\n17\tconst KALSHI_API_BASE = 'https://trading-api.kalshi.com/trade-api/v2';\n18\tconst KALSHI_DEMO_BASE = 'https://demo-api.kalshi.co/trade-api/v2';\n19\t\n20\tclass KalshiClient {\n21\t  constructor(options = {}) {\n22\t    this.apiKey = options.apiKey || process.env.KALSHI_API_KEY || null;\n23\t    this.apiSecret = options.apiSecret || process.env.KALSHI_API_SECRET || null;\n24\t    this.email = options.email || process.env.KALSHI_EMAIL || null;\n25\t    this.password = options.password || process.env.KALSHI_PASSWORD || null;\n26\t    this.useDemo = options.demo || process.env.KALSHI_DEMO === 'true' || false;\n27\t    this.mockMode = options.mock || (!this.apiKey && !this.email);\n28\t    this.baseUrl = this.useDemo ? KALSHI_DEMO_BASE : KALSHI_API_BASE;\n29\t    this.sessionToken = null;\n30\t    this.memberId = null;\n31\t\n32\t    if (this.mockMode) {\n33\t      console.log('[KalshiClient] Mock mode — no credentials found. Using synthetic data.');\n34\t    } else {\n35\t      const authMethod = this.apiKey ? 'API key' : 'email/password';\n36\t      const env = this.useDemo ? 'DEMO' : 'PRODUCTION';\n37\t      console.log(`[KalshiClient] Real mode (${env}) — auth via ${authMethod}.`);\n38\t    }\n39\t  }\n40\t\n41\t  // --- Authentication ---\n42\t\n43\t  async login() {\n44\t    if (this.mockMode) {\n45\t      this.sessionToken = 'mock-session-token';\n46\t      this.memberId = 'mock-member-id';\n47\t      return { token: this.sessionToken, member_id: this.memberId };\n48\t    }\n49\t\n50\t    if (this.apiKey) {\n51\t      // API key auth — no login needed, just set headers\n52\t      this.sessionToken = this.apiKey;\n53\t      return { token: '[api-key-auth]', member_id: 'api-key-user' };\n54\t    }\n55\t\n56\t    // Email/password login\n57\t    const body = { email: this.email, password: this.password };\n58\t    const resp = await this._request('POST', '/login', body);\n59\t    this.sessionToken = resp.token;\n60\t    this.memberId = resp.member_id;\n61\t    return resp;\n62\t  }\n63\t\n64\t  async logout() {\n65\t    if (this.mockMode) {\n66\t      this.sessionToken = null;\n67\t      return { ok: true };\n68\t    }\n69\t    const resp = await this._request('POST', '/logout');\n70\t    this.sessionToken = null;\n71\t    return resp;\n72\t  }\n73\t\n74\t  // --- Markets ---\n75\t\n76\t  async getMarkets(params = {}) {\n77\t    if (this.mockMode) return this._mockMarkets(params);\n78\t\n79\t    const query = this._buildQuery({\n80\t      limit: params.limit || 100,\n81\t      cursor: params.cursor || undefined,\n82\t      status: params.status || 'open',\n83\t      series_ticker: params.series_ticker || undefined,\n84\t      event_ticker: params.event_ticker || undefined,\n85\t    });\n86\t    const resp = await this._request('GET', `/markets${query}`);\n87\t    return resp;\n88\t  }\n89\t\n90\t  async getMarket(ticker) {\n91\t    if (this.mockMode) return this._mockMarket(ticker);\n92\t    return this._request('GET', `/markets/${ticker}`);\n93\t  }\n94\t\n95\t  async getEvent(eventTicker) {\n96\t    if (this.mockMode) return { event: { event_ticker: eventTicker, title: `Mock Event ${eventTicker}`, markets: [] } };\n97\t    return this._request('GET', `/events/${eventTicker}`);\n98\t  }\n99\t\n100\t  // --- Order Book ---\n101\t\n102\t  async getOrderBook(ticker, params = {}) {\n103\t    if (this.mockMode) return this._mockOrderBook(ticker);\n104\t\n105\t    const query = this._buildQuery({ depth: params.depth || 10 });\n106\t    return this._request('GET', `/markets/${ticker}/orderbook${query}`);\n107\t  }\n108\t\n109\t  // --- Candles / History ---\n110\t\n111\t  async getCandles(ticker, params = {}) {\n112\t    if (this.mockMode) return this._mockCandles(ticker, params);\n113\t\n114\t    const query = this._buildQuery({\n115\t      series_ticker: ticker,\n116\t      period_interval: params.interval || 60, // minutes\n117\t      start_ts: params.start_ts || undefined,\n118\t      end_ts: params.end_ts || undefined,\n119\t    });\n120\t    return this._request('GET', `/series/${ticker}/markets${query}`);\n121\t  }\n122\t\n123\t  async getMarketHistory(ticker, params = {}) {\n124\t    if (this.mockMode) return this._mockMarketHistory(ticker, params);\n125\t\n126\t    const query = this._buildQuery({\n127\t      limit: params.limit || 100,\n128\t      cursor: params.cursor || undefined,\n129\t      min_ts: params.min_ts || undefined,\n130\t      max_ts: params.max_ts || undefined,\n131\t    });\n132\t    return this._request('GET', `/markets/${ticker}/history${query}`);\n133\t  }\n134\t\n135\t  // --- Trading (Paper / Live) ---\n136\t\n137\t  async createOrder(params) {\n138\t    if (this.mockMode) return this._mockCreateOrder(params);\n139\t\n140\t    const body = {\n141\t      ticker: params.ticker,\n142\t      action: params.action, // 'buy' or 'sell'\n143\t      side: params.side, // 'yes' or 'no'\n144\t      type: params.type || 'limit',\n145\t      count: params.count,\n146\t      ...(params.type !== 'market' && { yes_price: params.yes_price, no_price: params.no_price }),\n147\t      expiration_ts: params.expiration_ts || undefined,\n148\t      sell_position_floor: params.sell_position_floor || undefined,\n149\t      buy_max_cost: params.buy_max_cost || undefined,\n150\t    };\n151\t    return this._request('POST', '/portfolio/orders', body);\n152\t  }\n153\t\n154\t  async cancelOrder(orderId) {\n155\t    if (this.mockMode) return { order: { order_id: orderId, status: 'canceled' } };\n156\t    return this._request('DELETE', `/portfolio/orders/${orderId}`);\n157\t  }\n158\t\n159\t  async getOrder(orderId) {\n160\t    if (this.mockMode) return { order: { order_id: orderId, status: 'resting', ticker: 'MOCK-TICKER' } };\n161\t    return this._request('GET', `/portfolio/orders/${orderId}`);\n162\t  }\n163\t\n164\t  async getOrders(params = {}) {\n165\t    if (this.mockMode) return { orders: [], cursor: null };\n166\t    const query = this._buildQuery({\n167\t      ticker: params.ticker || undefined,\n168\t      status: params.status || undefined,\n169\t      limit: params.limit || 100,\n170\t    });\n171\t    return this._request('GET', `/portfolio/orders${query}`);\n172\t  }\n173\t\n174\t  // --- Portfolio ---\n175\t\n176\t  async getPositions(params = {}) {\n177\t    if (this.mockMode) return { market_positions: [] };\n178\t    const query = this._buildQuery({\n179\t      limit: params.limit || 100,\n180\t      settlement_status: params.settlement_status || undefined,\n181\t      ticker: params.ticker || undefined,\n182\t    });\n183\t    return this._request('GET', `/portfolio/positions${query}`);\n184\t  }\n185\t\n186\t  async getBalance() {\n187\t    if (this.mockMode) return { balance: 10000_00 }; // $10,000.00 in cents\n188\t    return this._request('GET', '/portfolio/balance');\n189\t  }\n190\t\n191\t  async getFills(params = {}) {\n192\t    if (this.mockMode) return { fills: [], cursor: null };\n193\t    const query = this._buildQuery({\n194\t      ticker: params.ticker || undefined,\n195\t      limit: params.limit || 100,\n196\t    });\n197\t    return this._request('GET', `/portfolio/fills${query}`);\n198\t  }\n199\t\n200\t  // --- HTTP Layer ---\n201\t\n202\t  async _request(method, path, body = null) {\n203\t    return new Promise((resolve, reject) => {\n204\t      const url = new URL(this.baseUrl + path);\n205\t      const options = {\n206\t        hostname: url.hostname,\n207\t        port: 443,\n208\t        path: url.pathname + url.search,\n209\t        method,\n210\t        headers: {\n211\t          'Accept': 'application/json',\n212\t          'Content-Type': 'application/json',\n213\t        },\n214\t      };\n215\t\n216\t      // Auth header\n217\t      if (this.apiKey && !path.includes('/login')) {\n218\t        // RSA-signed API key auth (Kalshi v2)\n219\t        const timestamp = Math.floor(Date.now() / 1000).toString();\n220\t        options.headers['KALSHI-ACCESS-KEY'] = this.apiKey;\n221\t        options.headers['KALSHI-ACCESS-TIMESTAMP'] = timestamp;\n222\t        if (this.apiSecret) {\n223\t          const sigPayload = timestamp + method + path;\n224\t          options.headers['KALSHI-ACCESS-SIGNATURE'] = this._sign(sigPayload);\n225\t        }\n226\t      } else if (this.sessionToken && !path.includes('/login')) {\n227\t        options.headers['Authorization'] = `Bearer ${this.sessionToken}`;\n228\t      }\n229\t\n230\t      const req = https.request(options, (res) => {\n231\t        let data = '';\n232\t        res.on('data', chunk => data += chunk);\n233\t        res.on('end', () => {\n234\t          try {\n235\t            const parsed = JSON.parse(data);\n236\t            if (res.statusCode >= 400) {\n237\t              const err = new Error(`Kalshi API ${res.statusCode}: ${parsed.message || data}`);\n238\t              err.statusCode = res.statusCode;\n239\t              err.response = parsed;\n240\t              reject(err);\n241\t            } else {\n242\t              resolve(parsed);\n243\t            }\n244\t          } catch (e) {\n245\t            reject(new Error(`Failed to parse Kalshi response: ${data.slice(0, 200)}`));\n246\t          }\n247\t        });\n248\t      });\n249\t\n250\t      req.on('error', reject);\n251\t      req.setTimeout(15000, () => {\n252\t        req.destroy();\n253\t        reject(new Error('Kalshi API request timeout (15s)'));\n254\t      });\n255\t\n256\t      if (body) req.write(JSON.stringify(body));\n257\t      req.end();\n258\t    });\n259\t  }\n260\t\n261\t  _sign(payload) {\n262\t    if (!this.apiSecret) return '';\n263\t    try {\n264\t      const key = crypto.createPrivateKey(this.apiSecret);\n265\t      const sig = crypto.sign('RSA-SHA256', Buffer.from(payload), key);\n266\t      return sig.toString('base64');\n267\t    } catch (e) {\n268\t      console.error('[KalshiClient] Signing failed:', e.message);\n269\t      return '';\n270\t    }\n271\t  }\n272\t\n273\t  _buildQuery(params) {\n274\t    const entries = Object.entries(params).filter(([, v]) => v !== undefined && v !== null);\n275\t    if (entries.length === 0) return '';\n276\t    return '?' + entries.map(([k, v]) => `${encodeURIComponent(k)}=${encodeURIComponent(v)}`).join('&');\n277\t  }\n278\t\n279\t  // --- Mock Data Generators ---\n280\t\n281\t  _mockMarkets(params) {\n282\t    const tickers = [\n283\t      { ticker: 'KXBTC-25APR-100K', title: 'Bitcoin above $100K by April 2025?', yes_bid: 42, yes_ask: 44, volume: 25000 },\n284\t      { ticker: 'KXETH-25APR-5K', title: 'Ethereum above $5K by April 2025?', yes_bid: 25, yes_ask: 28, volume: 18000 },\n285\t      { ticker: 'KXFED-25MAY-HOLD', title: 'Fed holds rates in May 2025?', yes_bid: 72, yes_ask: 75, volume: 32000 },\n286\t      { ticker: 'KXGDP-25Q2-3PCT', title: 'GDP growth above 3% in Q2 2025?', yes_bid: 18, yes_ask: 22, volume: 15000 },\n287\t      { ticker: 'KXCPI-25APR-LT3', title: 'CPI under 3% in April 2025?', yes_bid: 68, yes_ask: 71, volume: 22000 },\n288\t      { ticker: 'KXSNP-25APR-5500', title: 'S&P 500 above 5500 by end of April?', yes_bid: 55, yes_ask: 58, volume: 28000 },\n289\t      { ticker: 'KXTSLA-25Q2-200', title: 'Tesla above $200 in Q2 2025?', yes_bid: 35, yes_ask: 38, volume: 12000 },\n290\t      { ticker: 'KXRAIN-25APR-NYC', title: 'Rain in NYC on April 15 2025?', yes_bid: 60, yes_ask: 63, volume: 8000 },\n291\t    ];\n292\t\n293\t    const limit = params.limit || 100;\n294\t    return {\n295\t      markets: tickers.slice(0, limit).map(t => ({\n296\t        ticker: t.ticker,\n297\t        event_ticker: t.ticker.split('-').slice(0, 2).join('-'),\n298\t        title: t.title,\n299\t        status: 'open',\n300\t        yes_bid: t.yes_bid,\n301\t        yes_ask: t.yes_ask,\n302\t        no_bid: 100 - t.yes_ask,\n303\t        no_ask: 100 - t.yes_bid,\n304\t        volume: t.volume,\n305\t        open_interest: Math.floor(t.volume * 0.4),\n306\t        last_price: Math.floor((t.yes_bid + t.yes_ask) / 2),\n307\t      })),\n308\t      cursor: null,\n309\t    };\n310\t  }\n311\t\n312\t  _mockMarket(ticker) {\n313\t    const mkt = this._mockMarkets({}).markets.find(m => m.ticker === ticker);\n314\t    if (mkt) return { market: mkt };\n315\t    return {\n316\t      market: {\n317\t        ticker,\n318\t        title: `Mock market ${ticker}`,\n319\t        status: 'open',\n320\t        yes_bid: 50,\n321\t        yes_ask: 53,\n322\t        no_bid: 47,\n323\t        no_ask: 50,\n324\t        volume: 10000,\n325\t        open_interest: 4000,\n326\t        last_price: 51,\n327\t      },\n328\t    };\n329\t  }\n330\t\n331\t  _mockOrderBook(ticker) {\n332\t    const midYes = 50;\n333\t    return {\n334\t      orderbook: {\n335\t        ticker,\n336\t        yes: Array.from({ length: 5 }, (_, i) => ({\n337\t          price: midYes - i - 1,\n338\t          quantity: Math.floor(Math.random() * 500) + 100,\n339\t        })),\n340\t        no: Array.from({ length: 5 }, (_, i) => ({\n341\t          price: (100 - midYes) - i - 1,\n342\t          quantity: Math.floor(Math.random() * 500) + 100,\n343\t        })),\n344\t      },\n345\t    };\n346\t  }\n347\t\n348\t  _mockCandles(ticker, params) {\n349\t    const count = 30;\n350\t    const now = Math.floor(Date.now() / 1000);\n351\t    const interval = (params.interval || 60) * 60; // seconds\n352\t    return {\n353\t      candles: Array.from({ length: count }, (_, i) => {\n354\t        const base = 45 + Math.random() * 10;\n355\t        return {\n356\t          ts: now - (count - i) * interval,\n357\t          open: Math.round(base),\n358\t          high: Math.round(base + Math.random() * 3),\n359\t          low: Math.round(base - Math.random() * 3),\n360\t          close: Math.round(base + (Math.random() - 0.5) * 4),\n361\t          volume: Math.floor(Math.random() * 1000) + 200,\n362\t        };\n363\t      }),\n364\t    };\n365\t  }\n366\t\n367\t  _mockMarketHistory(ticker, params) {\n368\t    const count = params.limit || 30;\n369\t    const now = Math.floor(Date.now() / 1000);\n370\t    return {\n371\t      history: Array.from({ length: count }, (_, i) => ({\n372\t        ts: now - (count - i) * 3600,\n373\t        yes_price: Math.round(45 + Math.random() * 10),\n374\t        volume: Math.floor(Math.random() * 500) + 50,\n375\t        open_interest: Math.floor(Math.random() * 5000) + 1000,\n376\t      })),\n377\t      cursor: null,\n378\t    };\n379\t  }\n380\t\n381\t  _mockCreateOrder(params) {\n382\t    const orderId = 'mock-' + Date.now().toString(36) + Math.random().toString(36).slice(2, 6);\n383\t    return {\n384\t      order: {\n385\t        order_id: orderId,\n386\t        ticker: params.ticker,\n387\t        action: params.action,\n388\t        side: params.side,\n389\t        type: params.type || 'limit',\n390\t        count: params.count,\n391\t        yes_price: params.yes_price || 50,\n392\t        status: params.type === 'market' ? 'executed' : 'resting',\n393\t        created_time: new Date().toISOString(),\n394\t        ...(params.type === 'market' && {\n395\t          avg_fill_price: params.yes_price || 50,\n396\t          filled_count: params.count,\n397\t        }),\n398\t      },\n399\t    };\n400\t  }\n401\t}\n402\t\n403\t// --- CLI Test ---\n404\tif (require.main === module) {\n405\t  (async () => {\n406\t    console.log('=== Kalshi Client Test ===\\n');\n407\t    const client = new KalshiClient({ mock: true });\n408\t\n409\t    // Auth\n410\t    const auth = await client.login();\n411\t    console.log('Login:', auth.token ? 'OK' : 'FAIL');\n412\t\n413\t    // Markets\n414\t    const markets = await client.getMarkets({ limit: 5 });\n415\t    console.log(`\\nMarkets (${markets.markets.length}):`);\n416\t    markets.markets.forEach(m => {\n417\t      console.log(`  ${m.ticker}: ${m.title} — yes ${m.yes_bid}/${m.yes_ask}, vol ${m.volume}`);\n418\t    });\n419\t\n420\t    // Single market\n421\t    const mkt = await client.getMarket('KXBTC-25APR-100K');\n422\t    console.log(`\\nSingle market: ${mkt.market.ticker} — ${mkt.market.title}`);\n423\t\n424\t    // Order book\n425\t    const ob = await client.getOrderBook('KXBTC-25APR-100K');\n426\t    console.log(`\\nOrder book (${ob.orderbook.ticker}): ${ob.orderbook.yes.length} yes levels, ${ob.orderbook.no.length} no levels`);\n427\t\n428\t    // Candles\n429\t    const candles = await client.getCandles('KXBTC-25APR', { interval: 60 });\n430\t    console.log(`\\nCandles: ${candles.candles.length} bars`);\n431\t    console.log(`  Latest: O=${candles.candles.at(-1).open} H=${candles.candles.at(-1).high} L=${candles.candles.at(-1).low} C=${candles.candles.at(-1).close}`);\n432\t\n433\t    // Market history\n434\t    const hist = await client.getMarketHistory('KXBTC-25APR-100K', { limit: 5 });\n435\t    console.log(`\\nHistory: ${hist.history.length} points`);\n436\t\n437\t    // Balance\n438\t    const bal = await client.getBalance();\n439\t    console.log(`\\nBalance: $${(bal.balance / 100).toFixed(2)}`);\n440\t\n441\t    // Place order\n442\t    const order = await client.createOrder({\n443\t      ticker: 'KXBTC-25APR-100K',\n444\t      action: 'buy',\n445\t      side: 'yes',\n446\t      type: 'limit',\n447\t      count: 10,\n448\t      yes_price: 43,\n449\t    });\n450\t    console.log(`\\nOrder placed: ${order.order.order_id} — ${order.order.status}`);\n451\t\n452\t    // Market order\n453\t    const mktOrder = await client.createOrder({\n454\t      ticker: 'KXFED-25MAY-HOLD',\n455\t      action: 'buy',\n456\t      side: 'yes',\n457\t      type: 'market',\n458\t      count: 5,\n459\t      yes_price: 74,\n460\t    });\n461\t    console.log(`Market order: ${mktOrder.order.order_id} — filled ${mktOrder.order.filled_count} @ ${mktOrder.order.avg_fill_price}`);\n462\t\n463\t    // Cancel\n464\t    const cancel = await client.cancelOrder(order.order.order_id);\n465\t    console.log(`Cancel: ${cancel.order.status}`);\n466\t\n467\t    // Positions\n468\t    const pos = await client.getPositions();\n469\t    console.log(`\\nPositions: ${pos.market_positions.length}`);\n470\t\n471\t    // Fills\n472\t    const fills = await client.getFills();\n473\t    console.log(`Fills: ${fills.fills.length}`);\n474\t\n475\t    console.log('\\n=== All tests passed ===');\n476\t  })().catch(e => {\n477\t    console.error('Test failed:', e);\n478\t    process.exit(1);\n479\t  });\n480\t}\n481\t\n482\tmodule.exports = { KalshiClient, KALSHI_API_BASE, KALSHI_DEMO_BASE };\n483\t"}]},"parent_tool_use_id":null,"session_id":"b7667f38-1014-4768-97a9-89f67c49d675","uuid":"ad807c1b-3721-4922-b805-f5e7d5465370","timestamp":"2026-04-04T19:28:57.133Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/chenyangcui/Documents/code/aicompany/planets/kalshi-traders/agents/bob/output/kalshi_client.js","content":"/**\n * Kalshi REST API Client Module\n *\n * Supports real Kalshi API v2 (trading-api.kalshi.com) and mock mode for testing.\n * Set KALSHI_API_KEY env var for real mode. Without it, falls back to mock mode.\n *\n * Usage:\n *   const { KalshiClient } = require('./kalshi_client');\n *   const client = new KalshiClient(); // auto-detects mock vs real\n *   await client.login();\n *   const markets = await client.getMarkets({ status: 'open', limit: 50 });\n */\n\nconst https = require('https');\nconst crypto = require('crypto');\n\nconst KALSHI_API_BASE = 'https://trading-api.kalshi.com/trade-api/v2';\nconst KALSHI_DEMO_BASE = 'https://demo-api.kalshi.co/trade-api/v2';\n\nclass KalshiClient {\n  constructor(options = {}) {\n    this.apiKey = options.apiKey || process.env.KALSHI_API_KEY || null;\n    this.apiSecret = options.apiSecret || process.env.KALSHI_API_SECRET || null;\n    this.email = options.email || process.env.KALSHI_EMAIL || null;\n    this.password = options.password || process.env.KALSHI_PASSWORD || null;\n    this.useDemo = options.demo || process.env.KALSHI_DEMO === 'true' || false;\n    this.mockMode = options.mock || (!this.apiKey && !this.email);\n    this.baseUrl = this.useDemo ? KALSHI_DEMO_BASE : KALSHI_API_BASE;\n    this.sessionToken = null;\n    this.memberId = null;\n\n    if (this.mockMode) {\n      console.log('[KalshiClient] Mock mode — no credentials found. Using synthetic data.');\n    } else {\n      const authMethod = this.apiKey ? 'API key' : 'email/password';\n      const env = this.useDemo ? 'DEMO' : 'PRODUCTION';\n      console.log(`[KalshiClient] Real mode (${env}) — auth via ${authMethod}.`);\n    }\n  }\n\n  // --- Authentication ---\n\n  async login() {\n    if (this.mockMode) {\n      this.sessionToken = 'mock-session-token';\n      this.memberId = 'mock-member-id';\n      return { token: this.sessionToken, member_id: this.memberId };\n    }\n\n    if (this.apiKey) {\n      // API key auth — no login needed, just set headers\n      this.sessionToken = this.apiKey;\n      return { token: '[api-key-auth]', member_id: 'api-key-user' };\n    }\n\n    // Email/password login\n    const body = { email: this.email, password: this.password };\n    const resp = await this._request('POST', '/login', body);\n    this.sessionToken = resp.token;\n    this.memberId = resp.member_id;\n    return resp;\n  }\n\n  async logout() {\n    if (this.mockMode) {\n      this.sessionToken = null;\n      return { ok: true };\n    }\n    const resp = await this._request('POST', '/logout');\n    this.sessionToken = null;\n    return resp;\n  }\n\n  // --- Markets ---\n\n  async getMarkets(params = {}) {\n    if (this.mockMode) return this._mockMarkets(params);\n\n    const query = this._buildQuery({\n      limit: params.limit || 100,\n      cursor: params.cursor || undefined,\n      status: params.status || 'open',\n      series_ticker: params.series_ticker || undefined,\n      event_ticker: params.event_ticker || undefined,\n    });\n    const resp = await this._request('GET', `/markets${query}`);\n    return resp;\n  }\n\n  async getMarket(ticker) {\n    if (this.mockMode) return this._mockMarket(ticker);\n    return this._request('GET', `/markets/${ticker}`);\n  }\n\n  async getEvent(eventTicker) {\n    if (this.mockMode) return { event: { event_ticker: eventTicker, title: `Mock Event ${eventTicker}`, markets: [] } };\n    return this._request('GET', `/events/${eventTicker}`);\n  }\n\n  // --- Order Book ---\n\n  async getOrderBook(ticker, params = {}) {\n    if (this.mockMode) return this._mockOrderBook(ticker);\n\n    const query = this._buildQuery({ depth: params.depth || 10 });\n    return this._request('GET', `/markets/${ticker}/orderbook${query}`);\n  }\n\n  // --- Candles / History ---\n\n  async getCandles(ticker, params = {}) {\n    if (this.mockMode) return this._mockCandles(ticker, params);\n\n    const query = this._buildQuery({\n      series_ticker: ticker,\n      period_interval: params.interval || 60, // minutes\n      start_ts: params.start_ts || undefined,\n      end_ts: params.end_ts || undefined,\n    });\n    return this._request('GET', `/series/${ticker}/markets${query}`);\n  }\n\n  async getMarketHistory(ticker, params = {}) {\n    if (this.mockMode) return this._mockMarketHistory(ticker, params);\n\n    const query = this._buildQuery({\n      limit: params.limit || 100,\n      cursor: params.cursor || undefined,\n      min_ts: params.min_ts || undefined,\n      max_ts: params.max_ts || undefined,\n    });\n    return this._request('GET', `/markets/${ticker}/history${query}`);\n  }\n\n  // --- Trading (Paper / Live) ---\n\n  async createOrder(params) {\n    if (this.mockMode) return this._mockCreateOrder(params);\n\n    const body = {\n      ticker: params.ticker,\n      action: params.action, // 'buy' or 'sell'\n      side: params.side, // 'yes' or 'no'\n      type: params.type || 'limit',\n      count: params.count,\n      ...(params.type !== 'market' && { yes_price: params.yes_price, no_price: params.no_price }),\n      expiration_ts: params.expiration_ts || undefined,\n      sell_position_floor: params.sell_position_floor || undefined,\n      buy_max_cost: params.buy_max_cost || undefined,\n    };\n    return this._request('POST', '/portfolio/orders', body);\n  }\n\n  async cancelOrder(orderId) {\n    if (this.mockMode) return { order: { order_id: orderId, status: 'canceled' } };\n    return this._request('DELETE', `/portfolio/orders/${orderId}`);\n  }\n\n  async getOrder(orderId) {\n    if (this.mockMode) return { order: { order_id: orderId, status: 'resting', ticker: 'MOCK-TICKER' } };\n    return this._request('GET', `/portfolio/orders/${orderId}`);\n  }\n\n  async getOrders(params = {}) {\n    if (this.mockMode) return { orders: [], cursor: null };\n    const query = this._buildQuery({\n      ticker: params.ticker || undefined,\n      status: params.status || undefined,\n      limit: params.limit || 100,\n    });\n    return this._request('GET', `/portfolio/orders${query}`);\n  }\n\n  // --- Portfolio ---\n\n  async getPositions(params = {}) {\n    if (this.mockMode) return { market_positions: [] };\n    const query = this._buildQuery({\n      limit: params.limit || 100,\n      settlement_status: params.settlement_status || undefined,\n      ticker: params.ticker || undefined,\n    });\n    return this._request('GET', `/portfolio/positions${query}`);\n  }\n\n  async getBalance() {\n    if (this.mockMode) return { balance: 10000_00 }; // $10,000.00 in cents\n    return this._request('GET', '/portfolio/balance');\n  }\n\n  async getFills(params = {}) {\n    if (this.mockMode) return { fills: [], cursor: null };\n    const query = this._buildQuery({\n      ticker: params.ticker || undefined,\n      limit: params.limit || 100,\n    });\n    return this._request('GET', `/portfolio/fills${query}`);\n  }\n\n  // --- HTTP Layer ---\n\n  async _request(method, path, body = null) {\n    return new Promise((resolve, reject) => {\n      const url = new URL(this.baseUrl + path);\n      const options = {\n        hostname: url.hostname,\n        port: 443,\n        path: url.pathname + url.search,\n        method,\n        headers: {\n          'Accept': 'application/json',\n          'Content-Type': 'application/json',\n        },\n      };\n\n      // Auth header\n      if (this.apiKey && !path.includes('/login')) {\n        // RSA-signed API key auth (Kalshi v2)\n        const timestamp = Math.floor(Date.now() / 1000).toString();\n        options.headers['KALSHI-ACCESS-KEY'] = this.apiKey;\n        options.headers['KALSHI-ACCESS-TIMESTAMP'] = timestamp;\n        if (this.apiSecret) {\n          const sigPayload = timestamp + method + path;\n          options.headers['KALSHI-ACCESS-SIGNATURE'] = this._sign(sigPayload);\n        }\n      } else if (this.sessionToken && !path.includes('/login')) {\n        options.headers['Authorization'] = `Bearer ${this.sessionToken}`;\n      }\n\n      const req = https.request(options, (res) => {\n        let data = '';\n        res.on('data', chunk => data += chunk);\n        res.on('end', () => {\n          try {\n            const parsed = JSON.parse(data);\n            if (res.statusCode >= 400) {\n              const err = new Error(`Kalshi API ${res.statusCode}: ${parsed.message || data}`);\n              err.statusCode = res.statusCode;\n              err.response = parsed;\n              reject(err);\n            } else {\n              resolve(parsed);\n            }\n          } catch (e) {\n            reject(new Error(`Failed to parse Kalshi response: ${data.slice(0, 200)}`));\n          }\n        });\n      });\n\n      req.on('error', reject);\n      req.setTimeout(15000, () => {\n        req.destroy();\n        reject(new Error('Kalshi API request timeout (15s)'));\n      });\n\n      if (body) req.write(JSON.stringify(body));\n      req.end();\n    });\n  }\n\n  _sign(payload) {\n    if (!this.apiSecret) return '';\n    try {\n      const key = crypto.createPrivateKey(this.apiSecret);\n      const sig = crypto.sign('RSA-SHA256', Buffer.from(payload), key);\n      return sig.toString('base64');\n    } catch (e) {\n      console.error('[KalshiClient] Signing failed:', e.message);\n      return '';\n    }\n  }\n\n  _buildQuery(params) {\n    const entries = Object.entries(params).filter(([, v]) => v !== undefined && v !== null);\n    if (entries.length === 0) return '';\n    return '?' + entries.map(([k, v]) => `${encodeURIComponent(k)}=${encodeURIComponent(v)}`).join('&');\n  }\n\n  // --- Mock Data Generators ---\n\n  _mockMarkets(params) {\n    const tickers = [\n      { ticker: 'KXBTC-25APR-100K', title: 'Bitcoin above $100K by April 2025?', yes_bid: 42, yes_ask: 44, volume: 25000 },\n      { ticker: 'KXETH-25APR-5K', title: 'Ethereum above $5K by April 2025?', yes_bid: 25, yes_ask: 28, volume: 18000 },\n      { ticker: 'KXFED-25MAY-HOLD', title: 'Fed holds rates in May 2025?', yes_bid: 72, yes_ask: 75, volume: 32000 },\n      { ticker: 'KXGDP-25Q2-3PCT', title: 'GDP growth above 3% in Q2 2025?', yes_bid: 18, yes_ask: 22, volume: 15000 },\n      { ticker: 'KXCPI-25APR-LT3', title: 'CPI under 3% in April 2025?', yes_bid: 68, yes_ask: 71, volume: 22000 },\n      { ticker: 'KXSNP-25APR-5500', title: 'S&P 500 above 5500 by end of April?', yes_bid: 55, yes_ask: 58, volume: 28000 },\n      { ticker: 'KXTSLA-25Q2-200', title: 'Tesla above $200 in Q2 2025?', yes_bid: 35, yes_ask: 38, volume: 12000 },\n      { ticker: 'KXRAIN-25APR-NYC', title: 'Rain in NYC on April 15 2025?', yes_bid: 60, yes_ask: 63, volume: 8000 },\n    ];\n\n    const limit = params.limit || 100;\n    return {\n      markets: tickers.slice(0, limit).map(t => ({\n        ticker: t.ticker,\n        event_ticker: t.ticker.split('-').slice(0, 2).join('-'),\n        title: t.title,\n        status: 'open',\n        yes_bid: t.yes_bid,\n        yes_ask: t.yes_ask,\n        no_bid: 100 - t.yes_ask,\n        no_ask: 100 - t.yes_bid,\n        volume: t.volume,\n        open_interest: Math.floor(t.volume * 0.4),\n        last_price: Math.floor((t.yes_bid + t.yes_ask) / 2),\n      })),\n      cursor: null,\n    };\n  }\n\n  _mockMarket(ticker) {\n    const mkt = this._mockMarkets({}).markets.find(m => m.ticker === ticker);\n    if (mkt) return { market: mkt };\n    return {\n      market: {\n        ticker,\n        title: `Mock market ${ticker}`,\n        status: 'open',\n        yes_bid: 50,\n        yes_ask: 53,\n        no_bid: 47,\n        no_ask: 50,\n        volume: 10000,\n        open_interest: 4000,\n        last_price: 51,\n      },\n    };\n  }\n\n  _mockOrderBook(ticker) {\n    const midYes = 50;\n    return {\n      orderbook: {\n        ticker,\n        yes: Array.from({ length: 5 }, (_, i) => ({\n          price: midYes - i - 1,\n          quantity: Math.floor(Math.random() * 500) + 100,\n        })),\n        no: Array.from({ length: 5 }, (_, i) => ({\n          price: (100 - midYes) - i - 1,\n          quantity: Math.floor(Math.random() * 500) + 100,\n        })),\n      },\n    };\n  }\n\n  _mockCandles(ticker, params) {\n    const count = 30;\n    const now = Math.floor(Date.now() / 1000);\n    const interval = (params.interval || 60) * 60; // seconds\n    return {\n      candles: Array.from({ length: count }, (_, i) => {\n        const base = 45 + Math.random() * 10;\n        return {\n          ts: now - (count - i) * interval,\n          open: Math.round(base),\n          high: Math.round(base + Math.random() * 3),\n          low: Math.round(base - Math.random() * 3),\n          close: Math.round(base + (Math.random() - 0.5) * 4),\n          volume: Math.floor(Math.random() * 1000) + 200,\n        };\n      }),\n    };\n  }\n\n  _mockMarketHistory(ticker, params) {\n    const count = params.limit || 30;\n    const now = Math.floor(Date.now() / 1000);\n    return {\n      history: Array.from({ length: count }, (_, i) => ({\n        ts: now - (count - i) * 3600,\n        yes_price: Math.round(45 + Math.random() * 10),\n        volume: Math.floor(Math.random() * 500) + 50,\n        open_interest: Math.floor(Math.random() * 5000) + 1000,\n      })),\n      cursor: null,\n    };\n  }\n\n  _mockCreateOrder(params) {\n    const orderId = 'mock-' + Date.now().toString(36) + Math.random().toString(36).slice(2, 6);\n    return {\n      order: {\n        order_id: orderId,\n        ticker: params.ticker,\n        action: params.action,\n        side: params.side,\n        type: params.type || 'limit',\n        count: params.count,\n        yes_price: params.yes_price || 50,\n        status: params.type === 'market' ? 'executed' : 'resting',\n        created_time: new Date().toISOString(),\n        ...(params.type === 'market' && {\n          avg_fill_price: params.yes_price || 50,\n          filled_count: params.count,\n        }),\n      },\n    };\n  }\n}\n\n// --- CLI Test ---\nif (require.main === module) {\n  (async () => {\n    console.log('=== Kalshi Client Test ===\\n');\n    const client = new KalshiClient({ mock: true });\n\n    // Auth\n    const auth = await client.login();\n    console.log('Login:', auth.token ? 'OK' : 'FAIL');\n\n    // Markets\n    const markets = await client.getMarkets({ limit: 5 });\n    console.log(`\\nMarkets (${markets.markets.length}):`);\n    markets.markets.forEach(m => {\n      console.log(`  ${m.ticker}: ${m.title} — yes ${m.yes_bid}/${m.yes_ask}, vol ${m.volume}`);\n    });\n\n    // Single market\n    const mkt = await client.getMarket('KXBTC-25APR-100K');\n    console.log(`\\nSingle market: ${mkt.market.ticker} — ${mkt.market.title}`);\n\n    // Order book\n    const ob = await client.getOrderBook('KXBTC-25APR-100K');\n    console.log(`\\nOrder book (${ob.orderbook.ticker}): ${ob.orderbook.yes.length} yes levels, ${ob.orderbook.no.length} no levels`);\n\n    // Candles\n    const candles = await client.getCandles('KXBTC-25APR', { interval: 60 });\n    console.log(`\\nCandles: ${candles.candles.length} bars`);\n    console.log(`  Latest: O=${candles.candles.at(-1).open} H=${candles.candles.at(-1).high} L=${candles.candles.at(-1).low} C=${candles.candles.at(-1).close}`);\n\n    // Market history\n    const hist = await client.getMarketHistory('KXBTC-25APR-100K', { limit: 5 });\n    console.log(`\\nHistory: ${hist.history.length} points`);\n\n    // Balance\n    const bal = await client.getBalance();\n    console.log(`\\nBalance: $${(bal.balance / 100).toFixed(2)}`);\n\n    // Place order\n    const order = await client.createOrder({\n      ticker: 'KXBTC-25APR-100K',\n      action: 'buy',\n      side: 'yes',\n      type: 'limit',\n      count: 10,\n      yes_price: 43,\n    });\n    console.log(`\\nOrder placed: ${order.order.order_id} — ${order.order.status}`);\n\n    // Market order\n    const mktOrder = await client.createOrder({\n      ticker: 'KXFED-25MAY-HOLD',\n      action: 'buy',\n      side: 'yes',\n      type: 'market',\n      count: 5,\n      yes_price: 74,\n    });\n    console.log(`Market order: ${mktOrder.order.order_id} — filled ${mktOrder.order.filled_count} @ ${mktOrder.order.avg_fill_price}`);\n\n    // Cancel\n    const cancel = await client.cancelOrder(order.order.order_id);\n    console.log(`Cancel: ${cancel.order.status}`);\n\n    // Positions\n    const pos = await client.getPositions();\n    console.log(`\\nPositions: ${pos.market_positions.length}`);\n\n    // Fills\n    const fills = await client.getFills();\n    console.log(`Fills: ${fills.fills.length}`);\n\n    console.log('\\n=== All tests passed ===');\n  })().catch(e => {\n    console.error('Test failed:', e);\n    process.exit(1);\n  });\n}\n\nmodule.exports = { KalshiClient, KALSHI_API_BASE, KALSHI_DEMO_BASE };\n","numLines":483,"startLine":1,"totalLines":483}}}
