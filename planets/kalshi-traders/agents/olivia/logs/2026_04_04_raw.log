{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015eGH7aTRnarzFbNEanrmVG","type":"tool_result","content":"1\t#!/usr/bin/env node\n2\t/**\n3\t * Signal Generator — T555\n4\t * Generates paper trade signals from correlation pairs using z-score mean reversion.\n5\t *\n6\t * Strategy:\n7\t *   For each correlated pair (from Phase 3), compute the rolling price spread.\n8\t *   When the spread z-score exceeds thresholds, generate BUY/SELL signals.\n9\t *   Mean-reversion: if spread is too wide (z > 2), bet on convergence.\n10\t *\n11\t * Usage:\n12\t *   node signal_generator.js                    # standalone\n13\t *   node run_pipeline.js --with-signals         # integrated\n14\t *\n15\t * Following: D5 (runnable system), C8 (verify output), C6 (knowledge.md ref)\n16\t */\n17\t\n18\t\"use strict\";\n19\t\n20\tconst fs = require(\"fs\");\n21\tconst path = require(\"path\");\n22\t\n23\t// ---------------------------------------------------------------------------\n24\t// Configuration\n25\t// ---------------------------------------------------------------------------\n26\tconst SIGNAL_CONFIG = {\n27\t  // Z-score thresholds for signal generation\n28\t  zScoreEntry: 2.0,       // |z| > 2.0 → generate signal\n29\t  zScoreExit: 0.5,        // |z| < 0.5 → close position (mean reverted)\n30\t  zScoreStop: 3.5,        // |z| > 3.5 → stop loss (divergence, not convergence)\n31\t\n32\t  // Rolling window for z-score calculation\n33\t  lookbackPeriod: 20,     // 20 price observations for mean/std\n34\t  minLookback: 10,        // minimum observations before generating signals\n35\t\n36\t  // Position sizing (fixed fractional)\n37\t  maxPositionSize: 5,     // max contracts per signal\n38\t  basePositionSize: 2,    // default contracts\n39\t  confidenceScaling: true, // scale position by arbitrage confidence\n40\t\n41\t  // Risk management\n42\t  maxOpenPositions: 6,    // max simultaneous open positions\n43\t  maxDrawdownPct: 10,     // stop trading if drawdown > 10% of capital\n44\t  initialCapital: 100,    // $100 starting capital (paper)\n45\t\n46\t  // Simulation\n47\t  priceHistoryLength: 50, // generate 50 price points for backtesting\n48\t  tradingFee: 0.01,       // $0.01 per contract per side\n49\t};\n50\t\n51\t// ---------------------------------------------------------------------------\n52\t// Z-Score Spread Calculator\n53\t// ---------------------------------------------------------------------------\n54\tfunction calculateSpreadZScores(pricesA, pricesB, lookback) {\n55\t  const n = Math.min(pricesA.length, pricesB.length);\n56\t  const spreads = [];\n57\t  const zScores = [];\n58\t\n59\t  // Calculate normalized spread series\n60\t  for (let i = 0; i < n; i++) {\n61\t    // Normalize prices to returns from start\n62\t    const baseA = pricesA[0] || 1;\n63\t    const baseB = pricesB[0] || 1;\n64\t    const normA = (pricesA[i] - baseA) / baseA;\n65\t    const normB = (pricesB[i] - baseB) / baseB;\n66\t    spreads.push(normA - normB);\n67\t  }\n68\t\n69\t  // Calculate rolling z-scores\n70\t  for (let i = 0; i < n; i++) {\n71\t    if (i < SIGNAL_CONFIG.minLookback) {\n72\t      zScores.push(null); // Not enough data\n73\t      continue;\n74\t    }\n75\t\n76\t    const windowStart = Math.max(0, i - lookback);\n77\t    const window = spreads.slice(windowStart, i);\n78\t\n79\t    const mean = window.reduce((a, b) => a + b, 0) / window.length;\n80\t    const variance = window.reduce((sum, s) => sum + (s - mean) ** 2, 0) / window.length;\n81\t    const std = Math.sqrt(variance) || 0.001;\n82\t\n83\t    zScores.push((spreads[i] - mean) / std);\n84\t  }\n85\t\n86\t  return { spreads, zScores };\n87\t}\n88\t\n89\t// ---------------------------------------------------------------------------\n90\t// Signal Generation\n91\t// ---------------------------------------------------------------------------\n92\tfunction generateSignals(correlationPairs, priceData) {\n93\t  const signals = [];\n94\t  const pairs = correlationPairs.pairs || [];\n95\t\n96\t  for (const pair of pairs) {\n97\t    if (!pair.is_arbitrage_opportunity) continue;\n98\t\n99\t    const tickerA = pair.market_a;\n100\t    const tickerB = pair.market_b;\n101\t\n102\t    const pricesA = priceData[tickerA];\n103\t    const pricesB = priceData[tickerB];\n104\t    if (!pricesA || !pricesB) continue;\n105\t\n106\t    const { spreads, zScores } = calculateSpreadZScores(\n107\t      pricesA, pricesB, SIGNAL_CONFIG.lookbackPeriod\n108\t    );\n109\t\n110\t    // Walk through z-scores and generate signals\n111\t    let inPosition = false;\n112\t    let positionDirection = null;\n113\t\n114\t    for (let i = 0; i < zScores.length; i++) {\n115\t      const z = zScores[i];\n116\t      if (z === null) continue;\n117\t\n118\t      const timestamp = new Date(\n119\t        Date.now() - (zScores.length - i) * 3600000 // 1 hour per tick\n120\t      ).toISOString();\n121\t\n122\t      // Entry signals\n123\t      if (!inPosition) {\n124\t        if (z > SIGNAL_CONFIG.zScoreEntry) {\n125\t          // Spread too wide (A overpriced vs B) → sell A, buy B\n126\t          const contracts = calculatePositionSize(pair.arbitrage_confidence, Math.abs(z));\n127\t          signals.push({\n128\t            id: `sig_${signals.length + 1}`,\n129\t            timestamp,\n130\t            type: \"ENTRY\",\n131\t            action_a: \"SELL\",\n132\t            action_b: \"BUY\",\n133\t            market_a: tickerA,\n134\t            market_b: tickerB,\n135\t            cluster: pair.cluster,\n136\t            z_score: parseFloat(z.toFixed(3)),\n137\t            spread: parseFloat(spreads[i].toFixed(4)),\n138\t            correlation: pair.pearson_correlation,\n139\t            confidence: pair.arbitrage_confidence,\n140\t            contracts,\n141\t            reason: `z=${z.toFixed(2)} > ${SIGNAL_CONFIG.zScoreEntry} — spread wide, mean reversion expected`,\n142\t          });\n143\t          inPosition = true;\n144\t          positionDirection = \"short_spread\";\n145\t        } else if (z < -SIGNAL_CONFIG.zScoreEntry) {\n146\t          // Spread too narrow (B overpriced vs A) → buy A, sell B\n147\t          const contracts = calculatePositionSize(pair.arbitrage_confidence, Math.abs(z));\n148\t          signals.push({\n149\t            id: `sig_${signals.length + 1}`,\n150\t            timestamp,\n151\t            type: \"ENTRY\",\n152\t            action_a: \"BUY\",\n153\t            action_b: \"SELL\",\n154\t            market_a: tickerA,\n155\t            market_b: tickerB,\n156\t            cluster: pair.cluster,\n157\t            z_score: parseFloat(z.toFixed(3)),\n158\t            spread: parseFloat(spreads[i].toFixed(4)),\n159\t            correlation: pair.pearson_correlation,\n160\t            confidence: pair.arbitrage_confidence,\n161\t            contracts,\n162\t            reason: `z=${z.toFixed(2)} < -${SIGNAL_CONFIG.zScoreEntry} — spread narrow, mean reversion expected`,\n163\t          });\n164\t          inPosition = true;\n165\t          positionDirection = \"long_spread\";\n166\t        }\n167\t      }\n168\t\n169\t      // Exit signals\n170\t      if (inPosition) {\n171\t        if (Math.abs(z) < SIGNAL_CONFIG.zScoreExit) {\n172\t          // Mean reverted → close position\n173\t          signals.push({\n174\t            id: `sig_${signals.length + 1}`,\n175\t            timestamp,\n176\t            type: \"EXIT\",\n177\t            action_a: positionDirection === \"short_spread\" ? \"BUY\" : \"SELL\",\n178\t            action_b: positionDirection === \"short_spread\" ? \"SELL\" : \"BUY\",\n179\t            market_a: tickerA,\n180\t            market_b: tickerB,\n181\t            cluster: pair.cluster,\n182\t            z_score: parseFloat(z.toFixed(3)),\n183\t            spread: parseFloat(spreads[i].toFixed(4)),\n184\t            reason: `z=${z.toFixed(2)} reverted to mean (< ${SIGNAL_CONFIG.zScoreExit})`,\n185\t          });\n186\t          inPosition = false;\n187\t          positionDirection = null;\n188\t        } else if (Math.abs(z) > SIGNAL_CONFIG.zScoreStop) {\n189\t          // Stop loss — spread diverging further\n190\t          signals.push({\n191\t            id: `sig_${signals.length + 1}`,\n192\t            timestamp,\n193\t            type: \"STOP\",\n194\t            action_a: positionDirection === \"short_spread\" ? \"BUY\" : \"SELL\",\n195\t            action_b: positionDirection === \"short_spread\" ? \"SELL\" : \"BUY\",\n196\t            market_a: tickerA,\n197\t            market_b: tickerB,\n198\t            cluster: pair.cluster,\n199\t            z_score: parseFloat(z.toFixed(3)),\n200\t            spread: parseFloat(spreads[i].toFixed(4)),\n201\t            reason: `z=${z.toFixed(2)} — stop loss triggered (> ${SIGNAL_CONFIG.zScoreStop})`,\n202\t          });\n203\t          inPosition = false;\n204\t          positionDirection = null;\n205\t        }\n206\t      }\n207\t    }\n208\t  }\n209\t\n210\t  return signals;\n211\t}\n212\t\n213\t// ---------------------------------------------------------------------------\n214\t// Position Sizing\n215\t// ---------------------------------------------------------------------------\n216\tfunction calculatePositionSize(confidence, absZ) {\n217\t  let size = SIGNAL_CONFIG.basePositionSize;\n218\t\n219\t  if (SIGNAL_CONFIG.confidenceScaling) {\n220\t    // Scale by confidence: higher confidence → larger position\n221\t    size = Math.round(SIGNAL_CONFIG.basePositionSize * confidence);\n222\t  }\n223\t\n224\t  // Bonus contract for very strong z-scores (> 2.5)\n225\t  if (absZ > 2.5) size += 1;\n226\t\n227\t  return Math.max(1, Math.min(size, SIGNAL_CONFIG.maxPositionSize));\n228\t}\n229\t\n230\t// ---------------------------------------------------------------------------\n231\t// Paper Trade Simulator\n232\t// ---------------------------------------------------------------------------\n233\tfunction simulatePaperTrades(signals, priceData) {\n234\t  const trades = [];\n235\t  let capital = SIGNAL_CONFIG.initialCapital;\n236\t  let peakCapital = capital;\n237\t  let maxDrawdown = 0;\n238\t  const openPositions = {};\n239\t\n240\t  for (const signal of signals) {\n241\t    const pairKey = `${signal.market_a}:${signal.market_b}`;\n242\t\n243\t    if (signal.type === \"ENTRY\") {\n244\t      // Open position\n245\t      if (Object.keys(openPositions).length >= SIGNAL_CONFIG.maxOpenPositions) continue;\n246\t\n247\t      // Check drawdown limit\n248\t      const drawdownPct = ((peakCapital - capital) / peakCapital) * 100;\n249\t      if (drawdownPct > SIGNAL_CONFIG.maxDrawdownPct) continue;\n250\t\n251\t      const pricesA = priceData[signal.market_a];\n252\t      const pricesB = priceData[signal.market_b];\n253\t      const entryPriceA = pricesA ? pricesA[pricesA.length - 1] : 50;\n254\t      const entryPriceB = pricesB ? pricesB[pricesB.length - 1] : 50;\n255\t\n256\t      openPositions[pairKey] = {\n257\t        signal,\n258\t        entryPriceA,\n259\t        entryPriceB,\n260\t        entrySpread: signal.spread,\n261\t        contracts: signal.contracts,\n262\t        entryTime: signal.timestamp,\n263\t      };\n264\t    } else if (signal.type === \"EXIT\" || signal.type === \"STOP\") {\n265\t      const pos = openPositions[pairKey];\n266\t      if (!pos) continue;\n267\t\n268\t      // Calculate P&L\n269\t      const exitSpread = signal.spread;\n270\t      const spreadChange = exitSpread - pos.entrySpread;\n271\t\n272\t      // P&L depends on direction:\n273\t      // short_spread: profit when spread narrows (spreadChange < 0)\n274\t      // long_spread: profit when spread widens (spreadChange > 0)\n275\t      const isShortSpread = pos.signal.action_a === \"SELL\";\n276\t      const rawPnlPerContract = isShortSpread ? -spreadChange : spreadChange;\n277\t\n278\t      // Convert spread change to dollar P&L (each cent = $0.01 per contract)\n279\t      // On Kalshi, contracts settle at $0 or $1, prices in cents\n280\t      const pnlCents = rawPnlPerContract * 100 * pos.contracts;\n281\t      const fees = SIGNAL_CONFIG.tradingFee * pos.contracts * 2; // entry + exit\n282\t      const netPnl = (pnlCents / 100) - fees;\n283\t\n284\t      capital += netPnl;\n285\t      peakCapital = Math.max(peakCapital, capital);\n286\t      maxDrawdown = Math.max(maxDrawdown, ((peakCapital - capital) / peakCapital) * 100);\n287\t\n288\t      trades.push({\n289\t        id: `trade_${trades.length + 1}`,\n290\t        entry_time: pos.entryTime,\n291\t        exit_time: signal.timestamp,\n292\t        exit_type: signal.type === \"STOP\" ? \"stop_loss\" : \"mean_reversion\",\n293\t        market_a: signal.market_a,\n294\t        market_b: signal.market_b,\n295\t        cluster: signal.cluster,\n296\t        direction: isShortSpread ? \"short_spread\" : \"long_spread\",\n297\t        contracts: pos.contracts,\n298\t        entry_spread: parseFloat(pos.entrySpread.toFixed(4)),\n299\t        exit_spread: parseFloat(exitSpread.toFixed(4)),\n300\t        entry_z: pos.signal.z_score,\n301\t        exit_z: signal.z_score,\n302\t        pnl_dollars: parseFloat(netPnl.toFixed(4)),\n303\t        fees_dollars: parseFloat(fees.toFixed(4)),\n304\t        outcome: netPnl > 0 ? \"win\" : \"loss\",\n305\t        capital_after: parseFloat(capital.toFixed(2)),\n306\t      });\n307\t\n308\t      delete openPositions[pairKey];\n309\t    }\n310\t  }\n311\t\n312\t  // Summary stats\n313\t  const wins = trades.filter(t => t.outcome === \"win\").length;\n314\t  const losses = trades.filter(t => t.outcome === \"loss\").length;\n315\t  const totalPnl = trades.reduce((s, t) => s + t.pnl_dollars, 0);\n316\t  const totalFees = trades.reduce((s, t) => s + t.fees_dollars, 0);\n317\t\n318\t  return {\n319\t    trades,\n320\t    summary: {\n321\t      initial_capital: SIGNAL_CONFIG.initialCapital,\n322\t      final_capital: parseFloat(capital.toFixed(2)),\n323\t      total_pnl: parseFloat(totalPnl.toFixed(4)),\n324\t      total_fees: parseFloat(totalFees.toFixed(4)),\n325\t      total_trades: trades.length,\n326\t      wins,\n327\t      losses,\n328\t      win_rate: trades.length > 0 ? parseFloat((wins / trades.length).toFixed(4)) : 0,\n329\t      avg_pnl_per_trade: trades.length > 0 ? parseFloat((totalPnl / trades.length).toFixed(4)) : 0,\n330\t      max_drawdown_pct: parseFloat(maxDrawdown.toFixed(2)),\n331\t      sharpe_estimate: estimateSharpe(trades),\n332\t    },\n333\t  };\n334\t}\n335\t\n336\tfunction estimateSharpe(trades) {\n337\t  if (trades.length < 2) return 0;\n338\t  const returns = trades.map(t => t.pnl_dollars);\n339\t  const mean = returns.reduce((a, b) => a + b, 0) / returns.length;\n340\t  const variance = returns.reduce((s, r) => s + (r - mean) ** 2, 0) / (returns.length - 1);\n341\t  const std = Math.sqrt(variance) || 0.001;\n342\t  // Annualize assuming ~252 trading days, ~2 trades/day\n343\t  const annualFactor = Math.sqrt(252 * 2);\n344\t  return parseFloat(((mean / std) * annualFactor).toFixed(2));\n345\t}\n346\t\n347\t// ---------------------------------------------------------------------------\n348\t// Price Data Generator (uses same seeded approach as run_pipeline.js)\n349\t// ---------------------------------------------------------------------------\n350\tfunction generatePriceData(correlationPairs) {\n351\t  const priceData = {};\n352\t  const allTickers = new Set();\n353\t\n354\t  for (const pair of (correlationPairs.pairs || [])) {\n355\t    allTickers.add(pair.market_a);\n356\t    allTickers.add(pair.market_b);\n357\t  }\n358\t\n359\t  // Shared market factors for correlated price generation\n360\t  const marketFactors = {};\n361\t  function getMarketFactor(category) {\n362\t    if (marketFactors[category]) return marketFactors[category];\n363\t    const seed = category.split(\"\").reduce((a, c) => a + c.charCodeAt(0), 0);\n364\t    const seededRandom = (n) => {\n365\t      const x = Math.sin(seed + n * 7.13) * 10000;\n366\t      return x - Math.floor(x);\n367\t    };\n368\t    const factors = [];\n369\t    for (let i = 0; i < SIGNAL_CONFIG.priceHistoryLength; i++) {\n370\t      factors.push((seededRandom(i) - 0.5) * 6);\n371\t    }\n372\t    marketFactors[category] = factors;\n373\t    return factors;\n374\t  }\n375\t\n376\t  for (const ticker of allTickers) {\n377\t    const seed = ticker.split(\"\").reduce((a, c) => a + c.charCodeAt(0), 0);\n378\t    const seededRandom = (n) => {\n379\t      const x = Math.sin(seed + n) * 10000;\n380\t      return x - Math.floor(x);\n381\t    };\n382\t\n383\t    let category = \"other\", basePrice = 50;\n384\t    if (ticker.includes(\"BTC\") || ticker.includes(\"ETH\") || ticker.includes(\"SOL\")) {\n385\t      category = \"crypto\";\n386\t      basePrice = ticker.includes(\"BTC\") ? 65 : ticker.includes(\"ETH\") ? 35 : 45;\n387\t    } else if (ticker.includes(\"INXW\") || ticker.includes(\"GDP\") || ticker.includes(\"CPI\")) {\n388\t      category = \"economics\";\n389\t      basePrice = ticker.includes(\"INXW\") ? 75 : 25;\n390\t    } else if (ticker.includes(\"KXNF\") || ticker.includes(\"NFP\")) {\n391\t      category = \"nfp\";\n392\t      basePrice = 26;\n393\t    } else if (ticker.includes(\"FED\")) {\n394\t      category = \"rates\";\n395\t      basePrice = 45;\n396\t    } else if (ticker.includes(\"OIL\")) {\n397\t      category = \"commodities\";\n398\t      basePrice = 22;\n399\t    }\n400\t\n401\t    const sharedFactor = getMarketFactor(category);\n402\t    const prices = [basePrice];\n403\t    for (let i = 1; i < SIGNAL_CONFIG.priceHistoryLength; i++) {\n404\t      const shared = sharedFactor[i] * 0.7;\n405\t      const noise = (seededRandom(i) - 0.5) * 4 * 0.3;\n406\t      const newPrice = Math.max(5, Math.min(95, prices[i - 1] + shared + noise));\n407\t      prices.push(Math.round(newPrice));\n408\t    }\n409\t    priceData[ticker] = prices;\n410\t  }\n411\t\n412\t  return priceData;\n413\t}\n414\t\n415\t// ---------------------------------------------------------------------------\n416\t// Main — Standalone Runner\n417\t// ---------------------------------------------------------------------------\n418\tfunction runSignalGeneration(correlationPairsInput) {\n419\t  // Load correlation pairs\n420\t  let correlationPairs;\n421\t  if (correlationPairsInput) {\n422\t    correlationPairs = correlationPairsInput;\n423\t  } else {\n424\t    const cpPath = path.join(__dirname, \"../../../public/correlation_pairs.json\");\n425\t    if (!fs.existsSync(cpPath)) {\n426\t      console.error(\"correlation_pairs.json not found. Run the pipeline first (Phases 1-3).\");\n427\t      process.exit(1);\n428\t    }\n429\t    correlationPairs = JSON.parse(fs.readFileSync(cpPath, \"utf8\"));\n430\t  }\n431\t\n432\t  console.log(\"\\n\" + \"=\".repeat(60));\n433\t  console.log(\"SIGNAL GENERATION — T555\");\n434\t  console.log(\"Z-Score Mean Reversion on Correlated Pairs\");\n435\t  console.log(\"=\".repeat(60));\n436\t  console.log(`Input: ${correlationPairs.total_pairs_analyzed || 0} pairs, ${correlationPairs.arbitrage_opportunities || 0} arb opportunities`);\n437\t  console.log(`Config: z_entry=${SIGNAL_CONFIG.zScoreEntry}, z_exit=${SIGNAL_CONFIG.zScoreExit}, z_stop=${SIGNAL_CONFIG.zScoreStop}`);\n438\t\n439\t  // Generate price data for simulation\n440\t  const priceData = generatePriceData(correlationPairs);\n441\t  console.log(`Generated ${Object.keys(priceData).length} price series (${SIGNAL_CONFIG.priceHistoryLength} ticks each)`);\n442\t\n443\t  // Generate signals\n444\t  const signals = generateSignals(correlationPairs, priceData);\n445\t  console.log(`\\nSignals generated: ${signals.length}`);\n446\t  console.log(`  ENTRY: ${signals.filter(s => s.type === \"ENTRY\").length}`);\n447\t  console.log(`  EXIT:  ${signals.filter(s => s.type === \"EXIT\").length}`);\n448\t  console.log(`  STOP:  ${signals.filter(s => s.type === \"STOP\").length}`);\n449\t\n450\t  // Simulate paper trades\n451\t  const results = simulatePaperTrades(signals, priceData);\n452\t  console.log(`\\nPaper Trade Results:`);\n453\t  console.log(`  Trades: ${results.summary.total_trades}`);\n454\t  console.log(`  Wins: ${results.summary.wins}, Losses: ${results.summary.losses}`);\n455\t  console.log(`  Win rate: ${(results.summary.win_rate * 100).toFixed(1)}%`);\n456\t  console.log(`  Total P&L: $${results.summary.total_pnl.toFixed(2)}`);\n457\t  console.log(`  Avg P&L/trade: $${results.summary.avg_pnl_per_trade.toFixed(4)}`);\n458\t  console.log(`  Max drawdown: ${results.summary.max_drawdown_pct}%`);\n459\t  console.log(`  Sharpe estimate: ${results.summary.sharpe_estimate}`);\n460\t  console.log(`  Capital: $${results.summary.initial_capital} → $${results.summary.final_capital}`);\n461\t\n462\t  // Write outputs\n463\t  const outputDir = path.join(__dirname);\n464\t\n465\t  const signalsOutput = {\n466\t    generated_at: new Date().toISOString(),\n467\t    task: \"T555\",\n468\t    strategy: \"z_score_mean_reversion\",\n469\t    config: { ...SIGNAL_CONFIG },\n470\t    input: {\n471\t      correlation_pairs: correlationPairs.total_pairs_analyzed || 0,\n472\t      arbitrage_opportunities: correlationPairs.arbitrage_opportunities || 0,\n473\t    },\n474\t    total_signals: signals.length,\n475\t    signals,\n476\t  };\n477\t  const signalsPath = path.join(outputDir, \"trade_signals.json\");\n478\t  fs.writeFileSync(signalsPath, JSON.stringify(signalsOutput, null, 2));\n479\t\n480\t  const resultsOutput = {\n481\t    generated_at: new Date().toISOString(),\n482\t    task: \"T555\",\n483\t    strategy: \"z_score_mean_reversion\",\n484\t    ...results,\n485\t  };\n486\t  const resultsPath = path.join(outputDir, \"paper_trade_results.json\");\n487\t  fs.writeFileSync(resultsPath, JSON.stringify(resultsOutput, null, 2));\n488\t\n489\t  console.log(`\\nOutput files:`);\n490\t  console.log(`  ${signalsPath}`);\n491\t  console.log(`  ${resultsPath}`);\n492\t\n493\t  return { signals: signalsOutput, results: resultsOutput };\n494\t}\n495\t\n496\t// Run standalone\n497\tif (require.main === module) {\n498\t  runSignalGeneration();\n499\t}\n500\t\n501\tmodule.exports = { runSignalGeneration, generateSignals, simulatePaperTrades, calculateSpreadZScores, SIGNAL_CONFIG };\n502\t"}]},"parent_tool_use_id":null,"session_id":"fc1382c3-94a3-431e-860e-868037b50443","uuid":"544874b4-1b95-466f-baea-e40cbc74b086","timestamp":"2026-04-04T07:25:10.308Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/chenyangcui/Documents/code/aicompany/planets/kalshi-traders/agents/bob/output/signal_generator.js","content":"#!/usr/bin/env node\n/**\n * Signal Generator — T555\n * Generates paper trade signals from correlation pairs using z-score mean reversion.\n *\n * Strategy:\n *   For each correlated pair (from Phase 3), compute the rolling price spread.\n *   When the spread z-score exceeds thresholds, generate BUY/SELL signals.\n *   Mean-reversion: if spread is too wide (z > 2), bet on convergence.\n *\n * Usage:\n *   node signal_generator.js                    # standalone\n *   node run_pipeline.js --with-signals         # integrated\n *\n * Following: D5 (runnable system), C8 (verify output), C6 (knowledge.md ref)\n */\n\n\"use strict\";\n\nconst fs = require(\"fs\");\nconst path = require(\"path\");\n\n// ---------------------------------------------------------------------------\n// Configuration\n// ---------------------------------------------------------------------------\nconst SIGNAL_CONFIG = {\n  // Z-score thresholds for signal generation\n  zScoreEntry: 2.0,       // |z| > 2.0 → generate signal\n  zScoreExit: 0.5,        // |z| < 0.5 → close position (mean reverted)\n  zScoreStop: 3.5,        // |z| > 3.5 → stop loss (divergence, not convergence)\n\n  // Rolling window for z-score calculation\n  lookbackPeriod: 20,     // 20 price observations for mean/std\n  minLookback: 10,        // minimum observations before generating signals\n\n  // Position sizing (fixed fractional)\n  maxPositionSize: 5,     // max contracts per signal\n  basePositionSize: 2,    // default contracts\n  confidenceScaling: true, // scale position by arbitrage confidence\n\n  // Risk management\n  maxOpenPositions: 6,    // max simultaneous open positions\n  maxDrawdownPct: 10,     // stop trading if drawdown > 10% of capital\n  initialCapital: 100,    // $100 starting capital (paper)\n\n  // Simulation\n  priceHistoryLength: 50, // generate 50 price points for backtesting\n  tradingFee: 0.01,       // $0.01 per contract per side\n};\n\n// ---------------------------------------------------------------------------\n// Z-Score Spread Calculator\n// ---------------------------------------------------------------------------\nfunction calculateSpreadZScores(pricesA, pricesB, lookback) {\n  const n = Math.min(pricesA.length, pricesB.length);\n  const spreads = [];\n  const zScores = [];\n\n  // Calculate normalized spread series\n  for (let i = 0; i < n; i++) {\n    // Normalize prices to returns from start\n    const baseA = pricesA[0] || 1;\n    const baseB = pricesB[0] || 1;\n    const normA = (pricesA[i] - baseA) / baseA;\n    const normB = (pricesB[i] - baseB) / baseB;\n    spreads.push(normA - normB);\n  }\n\n  // Calculate rolling z-scores\n  for (let i = 0; i < n; i++) {\n    if (i < SIGNAL_CONFIG.minLookback) {\n      zScores.push(null); // Not enough data\n      continue;\n    }\n\n    const windowStart = Math.max(0, i - lookback);\n    const window = spreads.slice(windowStart, i);\n\n    const mean = window.reduce((a, b) => a + b, 0) / window.length;\n    const variance = window.reduce((sum, s) => sum + (s - mean) ** 2, 0) / window.length;\n    const std = Math.sqrt(variance) || 0.001;\n\n    zScores.push((spreads[i] - mean) / std);\n  }\n\n  return { spreads, zScores };\n}\n\n// ---------------------------------------------------------------------------\n// Signal Generation\n// ---------------------------------------------------------------------------\nfunction generateSignals(correlationPairs, priceData) {\n  const signals = [];\n  const pairs = correlationPairs.pairs || [];\n\n  for (const pair of pairs) {\n    if (!pair.is_arbitrage_opportunity) continue;\n\n    const tickerA = pair.market_a;\n    const tickerB = pair.market_b;\n\n    const pricesA = priceData[tickerA];\n    const pricesB = priceData[tickerB];\n    if (!pricesA || !pricesB) continue;\n\n    const { spreads, zScores } = calculateSpreadZScores(\n      pricesA, pricesB, SIGNAL_CONFIG.lookbackPeriod\n    );\n\n    // Walk through z-scores and generate signals\n    let inPosition = false;\n    let positionDirection = null;\n\n    for (let i = 0; i < zScores.length; i++) {\n      const z = zScores[i];\n      if (z === null) continue;\n\n      const timestamp = new Date(\n        Date.now() - (zScores.length - i) * 3600000 // 1 hour per tick\n      ).toISOString();\n\n      // Entry signals\n      if (!inPosition) {\n        if (z > SIGNAL_CONFIG.zScoreEntry) {\n          // Spread too wide (A overpriced vs B) → sell A, buy B\n          const contracts = calculatePositionSize(pair.arbitrage_confidence, Math.abs(z));\n          signals.push({\n            id: `sig_${signals.length + 1}`,\n            timestamp,\n            type: \"ENTRY\",\n            action_a: \"SELL\",\n            action_b: \"BUY\",\n            market_a: tickerA,\n            market_b: tickerB,\n            cluster: pair.cluster,\n            z_score: parseFloat(z.toFixed(3)),\n            spread: parseFloat(spreads[i].toFixed(4)),\n            correlation: pair.pearson_correlation,\n            confidence: pair.arbitrage_confidence,\n            contracts,\n            reason: `z=${z.toFixed(2)} > ${SIGNAL_CONFIG.zScoreEntry} — spread wide, mean reversion expected`,\n          });\n          inPosition = true;\n          positionDirection = \"short_spread\";\n        } else if (z < -SIGNAL_CONFIG.zScoreEntry) {\n          // Spread too narrow (B overpriced vs A) → buy A, sell B\n          const contracts = calculatePositionSize(pair.arbitrage_confidence, Math.abs(z));\n          signals.push({\n            id: `sig_${signals.length + 1}`,\n            timestamp,\n            type: \"ENTRY\",\n            action_a: \"BUY\",\n            action_b: \"SELL\",\n            market_a: tickerA,\n            market_b: tickerB,\n            cluster: pair.cluster,\n            z_score: parseFloat(z.toFixed(3)),\n            spread: parseFloat(spreads[i].toFixed(4)),\n            correlation: pair.pearson_correlation,\n            confidence: pair.arbitrage_confidence,\n            contracts,\n            reason: `z=${z.toFixed(2)} < -${SIGNAL_CONFIG.zScoreEntry} — spread narrow, mean reversion expected`,\n          });\n          inPosition = true;\n          positionDirection = \"long_spread\";\n        }\n      }\n\n      // Exit signals\n      if (inPosition) {\n        if (Math.abs(z) < SIGNAL_CONFIG.zScoreExit) {\n          // Mean reverted → close position\n          signals.push({\n            id: `sig_${signals.length + 1}`,\n            timestamp,\n            type: \"EXIT\",\n            action_a: positionDirection === \"short_spread\" ? \"BUY\" : \"SELL\",\n            action_b: positionDirection === \"short_spread\" ? \"SELL\" : \"BUY\",\n            market_a: tickerA,\n            market_b: tickerB,\n            cluster: pair.cluster,\n            z_score: parseFloat(z.toFixed(3)),\n            spread: parseFloat(spreads[i].toFixed(4)),\n            reason: `z=${z.toFixed(2)} reverted to mean (< ${SIGNAL_CONFIG.zScoreExit})`,\n          });\n          inPosition = false;\n          positionDirection = null;\n        } else if (Math.abs(z) > SIGNAL_CONFIG.zScoreStop) {\n          // Stop loss — spread diverging further\n          signals.push({\n            id: `sig_${signals.length + 1}`,\n            timestamp,\n            type: \"STOP\",\n            action_a: positionDirection === \"short_spread\" ? \"BUY\" : \"SELL\",\n            action_b: positionDirection === \"short_spread\" ? \"SELL\" : \"BUY\",\n            market_a: tickerA,\n            market_b: tickerB,\n            cluster: pair.cluster,\n            z_score: parseFloat(z.toFixed(3)),\n            spread: parseFloat(spreads[i].toFixed(4)),\n            reason: `z=${z.toFixed(2)} — stop loss triggered (> ${SIGNAL_CONFIG.zScoreStop})`,\n          });\n          inPosition = false;\n          positionDirection = null;\n        }\n      }\n    }\n  }\n\n  return signals;\n}\n\n// ---------------------------------------------------------------------------\n// Position Sizing\n// ---------------------------------------------------------------------------\nfunction calculatePositionSize(confidence, absZ) {\n  let size = SIGNAL_CONFIG.basePositionSize;\n\n  if (SIGNAL_CONFIG.confidenceScaling) {\n    // Scale by confidence: higher confidence → larger position\n    size = Math.round(SIGNAL_CONFIG.basePositionSize * confidence);\n  }\n\n  // Bonus contract for very strong z-scores (> 2.5)\n  if (absZ > 2.5) size += 1;\n\n  return Math.max(1, Math.min(size, SIGNAL_CONFIG.maxPositionSize));\n}\n\n// ---------------------------------------------------------------------------\n// Paper Trade Simulator\n// ---------------------------------------------------------------------------\nfunction simulatePaperTrades(signals, priceData) {\n  const trades = [];\n  let capital = SIGNAL_CONFIG.initialCapital;\n  let peakCapital = capital;\n  let maxDrawdown = 0;\n  const openPositions = {};\n\n  for (const signal of signals) {\n    const pairKey = `${signal.market_a}:${signal.market_b}`;\n\n    if (signal.type === \"ENTRY\") {\n      // Open position\n      if (Object.keys(openPositions).length >= SIGNAL_CONFIG.maxOpenPositions) continue;\n\n      // Check drawdown limit\n      const drawdownPct = ((peakCapital - capital) / peakCapital) * 100;\n      if (drawdownPct > SIGNAL_CONFIG.maxDrawdownPct) continue;\n\n      const pricesA = priceData[signal.market_a];\n      const pricesB = priceData[signal.market_b];\n      const entryPriceA = pricesA ? pricesA[pricesA.length - 1] : 50;\n      const entryPriceB = pricesB ? pricesB[pricesB.length - 1] : 50;\n\n      openPositions[pairKey] = {\n        signal,\n        entryPriceA,\n        entryPriceB,\n        entrySpread: signal.spread,\n        contracts: signal.contracts,\n        entryTime: signal.timestamp,\n      };\n    } else if (signal.type === \"EXIT\" || signal.type === \"STOP\") {\n      const pos = openPositions[pairKey];\n      if (!pos) continue;\n\n      // Calculate P&L\n      const exitSpread = signal.spread;\n      const spreadChange = exitSpread - pos.entrySpread;\n\n      // P&L depends on direction:\n      // short_spread: profit when spread narrows (spreadChange < 0)\n      // long_spread: profit when spread widens (spreadChange > 0)\n      const isShortSpread = pos.signal.action_a === \"SELL\";\n      const rawPnlPerContract = isShortSpread ? -spreadChange : spreadChange;\n\n      // Convert spread change to dollar P&L (each cent = $0.01 per contract)\n      // On Kalshi, contracts settle at $0 or $1, prices in cents\n      const pnlCents = rawPnlPerContract * 100 * pos.contracts;\n      const fees = SIGNAL_CONFIG.tradingFee * pos.contracts * 2; // entry + exit\n      const netPnl = (pnlCents / 100) - fees;\n\n      capital += netPnl;\n      peakCapital = Math.max(peakCapital, capital);\n      maxDrawdown = Math.max(maxDrawdown, ((peakCapital - capital) / peakCapital) * 100);\n\n      trades.push({\n        id: `trade_${trades.length + 1}`,\n        entry_time: pos.entryTime,\n        exit_time: signal.timestamp,\n        exit_type: signal.type === \"STOP\" ? \"stop_loss\" : \"mean_reversion\",\n        market_a: signal.market_a,\n        market_b: signal.market_b,\n        cluster: signal.cluster,\n        direction: isShortSpread ? \"short_spread\" : \"long_spread\",\n        contracts: pos.contracts,\n        entry_spread: parseFloat(pos.entrySpread.toFixed(4)),\n        exit_spread: parseFloat(exitSpread.toFixed(4)),\n        entry_z: pos.signal.z_score,\n        exit_z: signal.z_score,\n        pnl_dollars: parseFloat(netPnl.toFixed(4)),\n        fees_dollars: parseFloat(fees.toFixed(4)),\n        outcome: netPnl > 0 ? \"win\" : \"loss\",\n        capital_after: parseFloat(capital.toFixed(2)),\n      });\n\n      delete openPositions[pairKey];\n    }\n  }\n\n  // Summary stats\n  const wins = trades.filter(t => t.outcome === \"win\").length;\n  const losses = trades.filter(t => t.outcome === \"loss\").length;\n  const totalPnl = trades.reduce((s, t) => s + t.pnl_dollars, 0);\n  const totalFees = trades.reduce((s, t) => s + t.fees_dollars, 0);\n\n  return {\n    trades,\n    summary: {\n      initial_capital: SIGNAL_CONFIG.initialCapital,\n      final_capital: parseFloat(capital.toFixed(2)),\n      total_pnl: parseFloat(totalPnl.toFixed(4)),\n      total_fees: parseFloat(totalFees.toFixed(4)),\n      total_trades: trades.length,\n      wins,\n      losses,\n      win_rate: trades.length > 0 ? parseFloat((wins / trades.length).toFixed(4)) : 0,\n      avg_pnl_per_trade: trades.length > 0 ? parseFloat((totalPnl / trades.length).toFixed(4)) : 0,\n      max_drawdown_pct: parseFloat(maxDrawdown.toFixed(2)),\n      sharpe_estimate: estimateSharpe(trades),\n    },\n  };\n}\n\nfunction estimateSharpe(trades) {\n  if (trades.length < 2) return 0;\n  const returns = trades.map(t => t.pnl_dollars);\n  const mean = returns.reduce((a, b) => a + b, 0) / returns.length;\n  const variance = returns.reduce((s, r) => s + (r - mean) ** 2, 0) / (returns.length - 1);\n  const std = Math.sqrt(variance) || 0.001;\n  // Annualize assuming ~252 trading days, ~2 trades/day\n  const annualFactor = Math.sqrt(252 * 2);\n  return parseFloat(((mean / std) * annualFactor).toFixed(2));\n}\n\n// ---------------------------------------------------------------------------\n// Price Data Generator (uses same seeded approach as run_pipeline.js)\n// ---------------------------------------------------------------------------\nfunction generatePriceData(correlationPairs) {\n  const priceData = {};\n  const allTickers = new Set();\n\n  for (const pair of (correlationPairs.pairs || [])) {\n    allTickers.add(pair.market_a);\n    allTickers.add(pair.market_b);\n  }\n\n  // Shared market factors for correlated price generation\n  const marketFactors = {};\n  function getMarketFactor(category) {\n    if (marketFactors[category]) return marketFactors[category];\n    const seed = category.split(\"\").reduce((a, c) => a + c.charCodeAt(0), 0);\n    const seededRandom = (n) => {\n      const x = Math.sin(seed + n * 7.13) * 10000;\n      return x - Math.floor(x);\n    };\n    const factors = [];\n    for (let i = 0; i < SIGNAL_CONFIG.priceHistoryLength; i++) {\n      factors.push((seededRandom(i) - 0.5) * 6);\n    }\n    marketFactors[category] = factors;\n    return factors;\n  }\n\n  for (const ticker of allTickers) {\n    const seed = ticker.split(\"\").reduce((a, c) => a + c.charCodeAt(0), 0);\n    const seededRandom = (n) => {\n      const x = Math.sin(seed + n) * 10000;\n      return x - Math.floor(x);\n    };\n\n    let category = \"other\", basePrice = 50;\n    if (ticker.includes(\"BTC\") || ticker.includes(\"ETH\") || ticker.includes(\"SOL\")) {\n      category = \"crypto\";\n      basePrice = ticker.includes(\"BTC\") ? 65 : ticker.includes(\"ETH\") ? 35 : 45;\n    } else if (ticker.includes(\"INXW\") || ticker.includes(\"GDP\") || ticker.includes(\"CPI\")) {\n      category = \"economics\";\n      basePrice = ticker.includes(\"INXW\") ? 75 : 25;\n    } else if (ticker.includes(\"KXNF\") || ticker.includes(\"NFP\")) {\n      category = \"nfp\";\n      basePrice = 26;\n    } else if (ticker.includes(\"FED\")) {\n      category = \"rates\";\n      basePrice = 45;\n    } else if (ticker.includes(\"OIL\")) {\n      category = \"commodities\";\n      basePrice = 22;\n    }\n\n    const sharedFactor = getMarketFactor(category);\n    const prices = [basePrice];\n    for (let i = 1; i < SIGNAL_CONFIG.priceHistoryLength; i++) {\n      const shared = sharedFactor[i] * 0.7;\n      const noise = (seededRandom(i) - 0.5) * 4 * 0.3;\n      const newPrice = Math.max(5, Math.min(95, prices[i - 1] + shared + noise));\n      prices.push(Math.round(newPrice));\n    }\n    priceData[ticker] = prices;\n  }\n\n  return priceData;\n}\n\n// ---------------------------------------------------------------------------\n// Main — Standalone Runner\n// ---------------------------------------------------------------------------\nfunction runSignalGeneration(correlationPairsInput) {\n  // Load correlation pairs\n  let correlationPairs;\n  if (correlationPairsInput) {\n    correlationPairs = correlationPairsInput;\n  } else {\n    const cpPath = path.join(__dirname, \"../../../public/correlation_pairs.json\");\n    if (!fs.existsSync(cpPath)) {\n      console.error(\"correlation_pairs.json not found. Run the pipeline first (Phases 1-3).\");\n      process.exit(1);\n    }\n    correlationPairs = JSON.parse(fs.readFileSync(cpPath, \"utf8\"));\n  }\n\n  console.log(\"\\n\" + \"=\".repeat(60));\n  console.log(\"SIGNAL GENERATION — T555\");\n  console.log(\"Z-Score Mean Reversion on Correlated Pairs\");\n  console.log(\"=\".repeat(60));\n  console.log(`Input: ${correlationPairs.total_pairs_analyzed || 0} pairs, ${correlationPairs.arbitrage_opportunities || 0} arb opportunities`);\n  console.log(`Config: z_entry=${SIGNAL_CONFIG.zScoreEntry}, z_exit=${SIGNAL_CONFIG.zScoreExit}, z_stop=${SIGNAL_CONFIG.zScoreStop}`);\n\n  // Generate price data for simulation\n  const priceData = generatePriceData(correlationPairs);\n  console.log(`Generated ${Object.keys(priceData).length} price series (${SIGNAL_CONFIG.priceHistoryLength} ticks each)`);\n\n  // Generate signals\n  const signals = generateSignals(correlationPairs, priceData);\n  console.log(`\\nSignals generated: ${signals.length}`);\n  console.log(`  ENTRY: ${signals.filter(s => s.type === \"ENTRY\").length}`);\n  console.log(`  EXIT:  ${signals.filter(s => s.type === \"EXIT\").length}`);\n  console.log(`  STOP:  ${signals.filter(s => s.type === \"STOP\").length}`);\n\n  // Simulate paper trades\n  const results = simulatePaperTrades(signals, priceData);\n  console.log(`\\nPaper Trade Results:`);\n  console.log(`  Trades: ${results.summary.total_trades}`);\n  console.log(`  Wins: ${results.summary.wins}, Losses: ${results.summary.losses}`);\n  console.log(`  Win rate: ${(results.summary.win_rate * 100).toFixed(1)}%`);\n  console.log(`  Total P&L: $${results.summary.total_pnl.toFixed(2)}`);\n  console.log(`  Avg P&L/trade: $${results.summary.avg_pnl_per_trade.toFixed(4)}`);\n  console.log(`  Max drawdown: ${results.summary.max_drawdown_pct}%`);\n  console.log(`  Sharpe estimate: ${results.summary.sharpe_estimate}`);\n  console.log(`  Capital: $${results.summary.initial_capital} → $${results.summary.final_capital}`);\n\n  // Write outputs\n  const outputDir = path.join(__dirname);\n\n  const signalsOutput = {\n    generated_at: new Date().toISOString(),\n    task: \"T555\",\n    strategy: \"z_score_mean_reversion\",\n    config: { ...SIGNAL_CONFIG },\n    input: {\n      correlation_pairs: correlationPairs.total_pairs_analyzed || 0,\n      arbitrage_opportunities: correlationPairs.arbitrage_opportunities || 0,\n    },\n    total_signals: signals.length,\n    signals,\n  };\n  const signalsPath = path.join(outputDir, \"trade_signals.json\");\n  fs.writeFileSync(signalsPath, JSON.stringify(signalsOutput, null, 2));\n\n  const resultsOutput = {\n    generated_at: new Date().toISOString(),\n    task: \"T555\",\n    strategy: \"z_score_mean_reversion\",\n    ...results,\n  };\n  const resultsPath = path.join(outputDir, \"paper_trade_results.json\");\n  fs.writeFileSync(resultsPath, JSON.stringify(resultsOutput, null, 2));\n\n  console.log(`\\nOutput files:`);\n  console.log(`  ${signalsPath}`);\n  console.log(`  ${resultsPath}`);\n\n  return { signals: signalsOutput, results: resultsOutput 