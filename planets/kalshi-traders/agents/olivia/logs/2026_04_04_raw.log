{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NFfXRnLA9CwJ2QDXWji7yr","type":"tool_result","content":"1\t#!/usr/bin/env node\n2\t/**\n3\t * Capital Floor — Post-Trade Safety Check (T587)\n4\t *\n5\t * Prevents negative capital by halting trading when capital drops below $50.\n6\t * Integrates with walk_forward_backtest.js and credential_manager.js audit log.\n7\t *\n8\t * Usage:\n9\t *   const { CapitalFloor } = require('./capital_floor');\n10\t *   const floor = new CapitalFloor({ floor: 50, auditLogger });\n11\t *   floor.check(currentCapital);  // throws if below floor\n12\t *\n13\t * Run standalone:\n14\t *   node capital_floor.js          # run tests\n15\t *\n16\t * Author: Bob (Backend Engineer)\n17\t */\n18\t\n19\tconst path = require('path');\n20\t\n21\tconst DEFAULT_FLOOR = 50; // $50 minimum capital\n22\t\n23\tclass CapitalFloor {\n24\t  constructor(options = {}) {\n25\t    this.floor = options.floor || DEFAULT_FLOOR;\n26\t    this.auditLogger = options.auditLogger || null;\n27\t    this.halted = false;\n28\t    this.haltReason = null;\n29\t    this.tradeCount = 0;\n30\t    this.breachHistory = [];\n31\t  }\n32\t\n33\t  /**\n34\t   * Check capital after a trade. Returns { ok, halted, capital, floor }.\n35\t   * If capital < floor, sets halted=true and logs CIRCUIT_BREAK event.\n36\t   */\n37\t  check(capital, tradeDetails = {}) {\n38\t    this.tradeCount++;\n39\t\n40\t    if (this.halted) {\n41\t      return {\n42\t        ok: false,\n43\t        halted: true,\n44\t        reason: this.haltReason,\n45\t        capital,\n46\t        floor: this.floor,\n47\t      };\n48\t    }\n49\t\n50\t    if (capital < this.floor) {\n51\t      this.halted = true;\n52\t      this.haltReason = `Capital $${capital.toFixed(2)} below floor $${this.floor}`;\n53\t\n54\t      const breach = {\n55\t        timestamp: new Date().toISOString(),\n56\t        capital: parseFloat(capital.toFixed(2)),\n57\t        floor: this.floor,\n58\t        tradeNumber: this.tradeCount,\n59\t        ...tradeDetails,\n60\t      };\n61\t      this.breachHistory.push(breach);\n62\t\n63\t      // Log to audit logger if available\n64\t      if (this.auditLogger) {\n65\t        this.auditLogger.log('CIRCUIT_BREAK_CAPITAL_FLOOR', {\n66\t          capital: parseFloat(capital.toFixed(2)),\n67\t          floor: this.floor,\n68\t          tradeNumber: this.tradeCount,\n69\t          reason: this.haltReason,\n70\t          ...tradeDetails,\n71\t        });\n72\t      }\n73\t\n74\t      return {\n75\t        ok: false,\n76\t        halted: true,\n77\t        reason: this.haltReason,\n78\t        capital: parseFloat(capital.toFixed(2)),\n79\t        floor: this.floor,\n80\t      };\n81\t    }\n82\t\n83\t    return {\n84\t      ok: true,\n85\t      halted: false,\n86\t      capital: parseFloat(capital.toFixed(2)),\n87\t      floor: this.floor,\n88\t    };\n89\t  }\n90\t\n91\t  /**\n92\t   * Reset the halt state (e.g., after manual review or capital injection).\n93\t   */\n94\t  reset() {\n95\t    this.halted = false;\n96\t    this.haltReason = null;\n97\t    if (this.auditLogger) {\n98\t      this.auditLogger.log('CAPITAL_FLOOR_RESET', { floor: this.floor });\n99\t    }\n100\t  }\n101\t\n102\t  status() {\n103\t    return {\n104\t      floor: this.floor,\n105\t      halted: this.halted,\n106\t      haltReason: this.haltReason,\n107\t      tradeCount: this.tradeCount,\n108\t      breachCount: this.breachHistory.length,\n109\t      breachHistory: this.breachHistory,\n110\t    };\n111\t  }\n112\t}\n113\t\n114\t// --- Tests ---\n115\t\n116\tfunction runTests() {\n117\t  let passed = 0;\n118\t  let failed = 0;\n119\t\n120\t  function assert(condition, name) {\n121\t    if (condition) { passed++; console.log(`  PASS: ${name}`); }\n122\t    else { failed++; console.log(`  FAIL: ${name}`); }\n123\t  }\n124\t\n125\t  // Mock audit logger\n126\t  const auditLog = [];\n127\t  const mockAudit = {\n128\t    log(event, details) { auditLog.push({ event, ...details }); }\n129\t  };\n130\t\n131\t  console.log('=== Capital Floor Tests (T587) ===\\n');\n132\t\n133\t  // Test 1: Normal capital — no halt\n134\t  console.log('--- Test 1: Normal capital ---');\n135\t  const f1 = new CapitalFloor({ floor: 50, auditLogger: mockAudit });\n136\t  const r1 = f1.check(500);\n137\t  assert(r1.ok === true, 'Capital $500 is OK');\n138\t  assert(r1.halted === false, 'Not halted');\n139\t\n140\t  // Test 2: Capital at floor — still OK\n141\t  console.log('--- Test 2: Capital at floor ---');\n142\t  const r2 = f1.check(50);\n143\t  assert(r2.ok === true, 'Capital $50 (at floor) is OK');\n144\t\n145\t  // Test 3: Capital below floor — halt\n146\t  console.log('--- Test 3: Capital below floor ---');\n147\t  const r3 = f1.check(49.99, { pair: 'BTC/ETH', signal: 'S001' });\n148\t  assert(r3.ok === false, 'Capital $49.99 triggers halt');\n149\t  assert(r3.halted === true, 'Halted flag set');\n150\t  assert(r3.reason.includes('below floor'), 'Reason mentions below floor');\n151\t\n152\t  // Test 4: Subsequent trades blocked while halted\n153\t  console.log('--- Test 4: Subsequent trades blocked ---');\n154\t  const r4 = f1.check(200);\n155\t  assert(r4.ok === false, 'Still halted even with $200');\n156\t  assert(r4.halted === true, 'Halt persists');\n157\t\n158\t  // Test 5: Audit logger received CIRCUIT_BREAK event\n159\t  console.log('--- Test 5: Audit log ---');\n160\t  const breakEvents = auditLog.filter(e => e.event === 'CIRCUIT_BREAK_CAPITAL_FLOOR');\n161\t  assert(breakEvents.length === 1, 'One CIRCUIT_BREAK event logged');\n162\t  assert(breakEvents[0].capital === 49.99, 'Logged correct capital');\n163\t  assert(breakEvents[0].floor === 50, 'Logged correct floor');\n164\t  assert(breakEvents[0].pair === 'BTC/ETH', 'Logged trade details');\n165\t\n166\t  // Test 6: Reset clears halt\n167\t  console.log('--- Test 6: Reset ---');\n168\t  f1.reset();\n169\t  const r6 = f1.check(100);\n170\t  assert(r6.ok === true, 'After reset, $100 is OK');\n171\t  const resetEvents = auditLog.filter(e => e.event === 'CAPITAL_FLOOR_RESET');\n172\t  assert(resetEvents.length === 1, 'Reset event logged');\n173\t\n174\t  // Test 7: Negative capital\n175\t  console.log('--- Test 7: Negative capital ---');\n176\t  const f7 = new CapitalFloor({ floor: 50, auditLogger: mockAudit });\n177\t  const r7 = f7.check(-10);\n178\t  assert(r7.ok === false, 'Negative capital triggers halt');\n179\t  assert(r7.capital === -10, 'Capital preserved in response');\n180\t\n181\t  // Test 8: Zero capital\n182\t  console.log('--- Test 8: Zero capital ---');\n183\t  const f8 = new CapitalFloor({ floor: 50, auditLogger: mockAudit });\n184\t  const r8 = f8.check(0);\n185\t  assert(r8.ok === false, 'Zero capital triggers halt');\n186\t\n187\t  // Test 9: Custom floor\n188\t  console.log('--- Test 9: Custom floor ---');\n189\t  const f9 = new CapitalFloor({ floor: 100 });\n190\t  const r9a = f9.check(99);\n191\t  assert(r9a.ok === false, 'Custom floor $100 — $99 triggers halt');\n192\t\n193\t  // Test 10: Status tracking\n194\t  console.log('--- Test 10: Status ---');\n195\t  const f10 = new CapitalFloor({ floor: 50, auditLogger: mockAudit });\n196\t  f10.check(200);\n197\t  f10.check(30);\n198\t  const status = f10.status();\n199\t  assert(status.tradeCount === 2, 'Trade count = 2');\n200\t  assert(status.breachCount === 1, 'Breach count = 1');\n201\t  assert(status.halted === true, 'Status shows halted');\n202\t\n203\t  // Test 11: No audit logger — still works\n204\t  console.log('--- Test 11: No audit logger ---');\n205\t  const f11 = new CapitalFloor({ floor: 50 });\n206\t  const r11 = f11.check(10);\n207\t  assert(r11.ok === false, 'Works without audit logger');\n208\t\n209\t  console.log(`\\n=== Results: ${passed} passed, ${failed} failed ===`);\n210\t  return failed === 0;\n211\t}\n212\t\n213\tif (require.main === module) {\n214\t  const ok = runTests();\n215\t  process.exit(ok ? 0 : 1);\n216\t}\n217\t\n218\tmodule.exports = { CapitalFloor, DEFAULT_FLOOR };\n219\t"}]},"parent_tool_use_id":null,"session_id":"c6f3c1bb-0f3d-4a75-b264-34cb1de23784","uuid":"d194da84-4c8b-45d1-8c0e-69d202d6bf24","timestamp":"2026-04-04T20:41:03.125Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/chenyangcui/Documents/code/aicompany/planets/kalshi-traders/agents/bob/output/capital_floor.js","content":"#!/usr/bin/env node\n/**\n * Capital Floor — Post-Trade Safety Check (T587)\n *\n * Prevents negative capital by halting trading when capital drops below $50.\n * Integrates with walk_forward_backtest.js and credential_manager.js audit log.\n *\n * Usage:\n *   const { CapitalFloor } = require('./capital_floor');\n *   const floor = new CapitalFloor({ floor: 50, auditLogger });\n *   floor.check(currentCapital);  // throws if below floor\n *\n * Run standalone:\n *   node capital_floor.js          # run tests\n *\n * Author: Bob (Backend Engineer)\n */\n\nconst path = require('path');\n\nconst DEFAULT_FLOOR = 50; // $50 minimum capital\n\nclass CapitalFloor {\n  constructor(options = {}) {\n    this.floor = options.floor || DEFAULT_FLOOR;\n    this.auditLogger = options.auditLogger || null;\n    this.halted = false;\n    this.haltReason = null;\n    this.tradeCount = 0;\n    this.breachHistory = [];\n  }\n\n  /**\n   * Check capital after a trade. Returns { ok, halted, capital, floor }.\n   * If capital < floor, sets halted=true and logs CIRCUIT_BREAK event.\n   */\n  check(capital, tradeDetails = {}) {\n    this.tradeCount++;\n\n    if (this.halted) {\n      return {\n        ok: false,\n        halted: true,\n        reason: this.haltReason,\n        capital,\n        floor: this.floor,\n      };\n    }\n\n    if (capital < this.floor) {\n      this.halted = true;\n      this.haltReason = `Capital $${capital.toFixed(2)} below floor $${this.floor}`;\n\n      const breach = {\n        timestamp: new Date().toISOString(),\n        capital: parseFloat(capital.toFixed(2)),\n        floor: this.floor,\n        tradeNumber: this.tradeCount,\n        ...tradeDetails,\n      };\n      this.breachHistory.push(breach);\n\n      // Log to audit logger if available\n      if (this.auditLogger) {\n        this.auditLogger.log('CIRCUIT_BREAK_CAPITAL_FLOOR', {\n          capital: parseFloat(capital.toFixed(2)),\n          floor: this.floor,\n          tradeNumber: this.tradeCount,\n          reason: this.haltReason,\n          ...tradeDetails,\n        });\n      }\n\n      return {\n        ok: false,\n        halted: true,\n        reason: this.haltReason,\n        capital: parseFloat(capital.toFixed(2)),\n        floor: this.floor,\n      };\n    }\n\n    return {\n      ok: true,\n      halted: false,\n      capital: parseFloat(capital.toFixed(2)),\n      floor: this.floor,\n    };\n  }\n\n  /**\n   * Reset the halt state (e.g., after manual review or capital injection).\n   */\n  reset() {\n    this.halted = false;\n    this.haltReason = null;\n    if (this.auditLogger) {\n      this.auditLogger.log('CAPITAL_FLOOR_RESET', { floor: this.floor });\n    }\n  }\n\n  status() {\n    return {\n      floor: this.floor,\n      halted: this.halted,\n      haltReason: this.haltReason,\n      tradeCount: this.tradeCount,\n      breachCount: this.breachHistory.length,\n      breachHistory: this.breachHistory,\n    };\n  }\n}\n\n// --- Tests ---\n\nfunction runTests() {\n  let passed = 0;\n  let failed = 0;\n\n  function assert(condition, name) {\n    if (condition) { passed++; console.log(`  PASS: ${name}`); }\n    else { failed++; console.log(`  FAIL: ${name}`); }\n  }\n\n  // Mock audit logger\n  const auditLog = [];\n  const mockAudit = {\n    log(event, details) { auditLog.push({ event, ...details }); }\n  };\n\n  console.log('=== Capital Floor Tests (T587) ===\\n');\n\n  // Test 1: Normal capital — no halt\n  console.log('--- Test 1: Normal capital ---');\n  const f1 = new CapitalFloor({ floor: 50, auditLogger: mockAudit });\n  const r1 = f1.check(500);\n  assert(r1.ok === true, 'Capital $500 is OK');\n  assert(r1.halted === false, 'Not halted');\n\n  // Test 2: Capital at floor — still OK\n  console.log('--- Test 2: Capital at floor ---');\n  const r2 = f1.check(50);\n  assert(r2.ok === true, 'Capital $50 (at floor) is OK');\n\n  // Test 3: Capital below floor — halt\n  console.log('--- Test 3: Capital below floor ---');\n  const r3 = f1.check(49.99, { pair: 'BTC/ETH', signal: 'S001' });\n  assert(r3.ok === false, 'Capital $49.99 triggers halt');\n  assert(r3.halted === true, 'Halted flag set');\n  assert(r3.reason.includes('below floor'), 'Reason mentions below floor');\n\n  // Test 4: Subsequent trades blocked while halted\n  console.log('--- Test 4: Subsequent trades blocked ---');\n  const r4 = f1.check(200);\n  assert(r4.ok === false, 'Still halted even with $200');\n  assert(r4.halted === true, 'Halt persists');\n\n  // Test 5: Audit logger received CIRCUIT_BREAK event\n  console.log('--- Test 5: Audit log ---');\n  const breakEvents = auditLog.filter(e => e.event === 'CIRCUIT_BREAK_CAPITAL_FLOOR');\n  assert(breakEvents.length === 1, 'One CIRCUIT_BREAK event logged');\n  assert(breakEvents[0].capital === 49.99, 'Logged correct capital');\n  assert(breakEvents[0].floor === 50, 'Logged correct floor');\n  assert(breakEvents[0].pair === 'BTC/ETH', 'Logged trade details');\n\n  // Test 6: Reset clears halt\n  console.log('--- Test 6: Reset ---');\n  f1.reset();\n  const r6 = f1.check(100);\n  assert(r6.ok === true, 'After reset, $100 is OK');\n  const resetEvents = auditLog.filter(e => e.event === 'CAPITAL_FLOOR_RESET');\n  assert(resetEvents.length === 1, 'Reset event logged');\n\n  // Test 7: Negative capital\n  console.log('--- Test 7: Negative capital ---');\n  const f7 = new CapitalFloor({ floor: 50, auditLogger: mockAudit });\n  const r7 = f7.check(-10);\n  assert(r7.ok === false, 'Negative capital triggers halt');\n  assert(r7.capital === -10, 'Capital preserved in response');\n\n  // Test 8: Zero capital\n  console.log('--- Test 8: Zero capital ---');\n  const f8 = new CapitalFloor({ floor: 50, auditLogger: mockAudit });\n  const r8 = f8.check(0);\n  assert(r8.ok === false, 'Zero capital triggers halt');\n\n  // Test 9: Custom floor\n  console.log('--- Test 9: Custom floor ---');\n  const f9 = new CapitalFloor({ floor: 100 });\n  const r9a = f9.check(99);\n  assert(r9a.ok === false, 'Custom floor $100 — $99 triggers halt');\n\n  // Test 10: Status tracking\n  console.log('--- Test 10: Status ---');\n  const f10 = new CapitalFloor({ floor: 50, auditLogger: mockAudit });\n  f10.check(200);\n  f10.check(30);\n  const status = f10.status();\n  assert(status.tradeCount === 2, 'Trade count = 2');\n  assert(status.breachCount === 1, 'Breach count = 1');\n  assert(status.halted === true, 'Status shows halted');\n\n  // Test 11: No audit logger — still works\n  console.log('--- Test 11: No audit logger ---');\n  const f11 = new CapitalFloor({ floor: 50 });\n  const r11 = f11.check(10);\n  assert(r11.ok === false, 'Works without audit logger');\n\n  console.log(`\\n=== Results: ${passed} passed, ${failed} failed ===`);\n  return failed === 0;\n}\n\nif (require.main === module) {\n  const ok = runTests();\n  process.exit(ok ? 0 : 1);\n}\n\nmodule.exports = { CapitalFloor, DEFAULT_FLOOR };\n","numLines":219,"startLine":1,"totalLines":219}}}
