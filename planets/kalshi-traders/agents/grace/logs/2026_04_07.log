{"type": "item.completed", "item": {"id": "item_46", "type": "command_execution", "command": "/bin/zsh -lc \"nl -ba ../../output/grace/verify_live_phase1_fixture.js | sed -n '1,260p'\"", "aggregated_output": "     1\t#!/usr/bin/env node\n     2\t\"use strict\";\n     3\t\n     4\tconst fs = require(\"fs\");\n     5\tconst path = require(\"path\");\n     6\tconst { runFilter, loadMarketsFromFile } = require(\"./market_filter\");\n     7\t\n     8\tconst FIXTURE_PATH = path.join(__dirname, \"live_phase1_fixture.json\");\n     9\tconst EXPECTED_PATH = path.join(__dirname, \"live_phase1_expected.json\");\n    10\tconst OUTPUT_PATH = path.join(__dirname, \"filtered_markets_live_fixture.json\");\n    11\tconst REPORT_PATH = path.join(__dirname, \"live_phase1_validation_report.md\");\n    12\t\n    13\tfunction assertEqual(actual, expected, message) {\n    14\t  if (actual !== expected) {\n    15\t    throw new Error(`${message}: expected ${expected}, received ${actual}`);\n    16\t  }\n    17\t}\n    18\t\n    19\tfunction assertArrayEqual(actual, expected, message) {\n    20\t  const actualSorted = [...actual].sort();\n    21\t  const expectedSorted = [...expected].sort();\n    22\t\n    23\t  if (actualSorted.length !== expectedSorted.length) {\n    24\t    throw new Error(`${message}: expected ${expectedSorted.length} items, received ${actualSorted.length}`);\n    25\t  }\n    26\t\n    27\t  for (let index = 0; index < actualSorted.length; index += 1) {\n    28\t    if (actualSorted[index] !== expectedSorted[index]) {\n    29\t      throw new Error(`${message}: mismatch at index ${index}, expected ${expectedSorted[index]}, received ${actualSorted[index]}`);\n    30\t    }\n    31\t  }\n    32\t}\n    33\t\n    34\tfunction assertDateNotInFuture(isoString, message) {\n    35\t  const parsed = Date.parse(isoString);\n    36\t  if (Number.isNaN(parsed)) {\n    37\t    throw new Error(`${message}: invalid timestamp ${isoString}`);\n    38\t  }\n    39\t\n    40\t  if (parsed > Date.now()) {\n    41\t    throw new Error(`${message}: ${isoString} is in the future`);\n    42\t  }\n    43\t}\n    44\t\n    45\tfunction assertChronologicalOrder(earlier, later, message) {\n    46\t  const earlierMs = Date.parse(earlier);\n    47\t  const laterMs = Date.parse(later);\n    48\t\n    49\t  if (Number.isNaN(earlierMs) || Number.isNaN(laterMs)) {\n    50\t    throw new Error(`${message}: invalid timestamps ${earlier} -> ${later}`);\n    51\t  }\n    52\t\n    53\t  if (laterMs < earlierMs) {\n    54\t    throw new Error(`${message}: ${later} is earlier than ${earlier}`);\n    55\t  }\n    56\t}\n    57\t\n    58\tfunction validateTitleSanity(markets) {\n    59\t  const problems = [];\n    60\t\n    61\t  for (const market of markets) {\n    62\t    const title = String(market.title || \"\");\n    63\t    const lowerTitle = title.toLowerCase();\n    64\t    const percentMatches = [...title.matchAll(/(\\d+(?:\\.\\d+)?)%/g)];\n    65\t\n    66\t    if (lowerTitle.includes(\"unemployment\")) {\n    67\t      for (const match of percentMatches) {\n    68\t        if (Number(match[1]) > 100) {\n    69\t          problems.push(`${market.ticker}: unemployment threshold ${match[1]}% is impossible`);\n    70\t        }\n    71\t      }\n    72\t    }\n    73\t\n    74\t    if (lowerTitle.includes(\"bitcoin dominance\")) {\n    75\t      for (const match of percentMatches) {\n    76\t        if (Number(match[1]) > 100) {\n    77\t          problems.push(`${market.ticker}: bitcoin dominance threshold ${match[1]}% exceeds 100%`);\n    78\t        }\n    79\t      }\n    80\t    }\n    81\t\n    82\t    if (lowerTitle.includes(\"solana\") && title.includes(\"$\")) {\n    83\t      const priceMatches = [...title.matchAll(/\\$([0-9][0-9,]*(?:\\.\\d+)?)/g)];\n    84\t      for (const match of priceMatches) {\n    85\t        const value = Number(match[1].replace(/,/g, \"\"));\n    86\t        if (value > 5000) {\n    87\t          problems.push(`${market.ticker}: Solana threshold $${value} is implausibly high for this fixture pack`);\n    88\t        }\n    89\t      }\n    90\t    }\n    91\t  }\n    92\t\n    93\t  return problems;\n    94\t}\n    95\t\n    96\tfunction buildOutcomeLookup({ output, rawFixtureMarkets }) {\n    97\t  const outcomes = new Map();\n    98\t\n    99\t  for (const market of output.qualifying_markets) {\n   100\t    outcomes.set(market.ticker, \"qualifying\");\n   101\t  }\n   102\t\n   103\t  for (const market of output.excluded_markets) {\n   104\t    if (market.reason === \"middle_range_excluded\") {\n   105\t      outcomes.set(market.ticker, \"excluded_middle_range\");\n   106\t      continue;\n   107\t    }\n   108\t\n   109\t    if (market.reason === \"extreme_ratio\") {\n   110\t      outcomes.set(market.ticker, \"extreme_ratio\");\n   111\t    }\n   112\t  }\n   113\t\n   114\t  const lowVolumeTickers = rawFixtureMarkets\n   115\t    .filter((market) => {\n   116\t      const ticker = String(market.ticker || market.marketTicker || \"\");\n   117\t      return ticker && !outcomes.has(ticker) && !output.rejected_markets.some((entry) => entry.ticker === ticker);\n   118\t    })\n   119\t    .map((market) => String(market.ticker || market.marketTicker || \"\"))\n   120\t    .filter(Boolean);\n   121\t\n   122\t  for (const ticker of lowVolumeTickers) {\n   123\t    outcomes.set(ticker, \"excluded_low_volume\");\n   124\t  }\n   125\t\n   126\t  for (const market of output.rejected_markets) {\n   127\t    outcomes.set(market.ticker, \"rejected_invalid_market\");\n   128\t  }\n   129\t\n   130\t  return outcomes;\n   131\t}\n   132\t\n   133\tfunction writeReport({ fixture, output, expected, sanityProblems, lowVolumeTickers }) {\n   134\t  const report = `# Sprint 6 T816 \u2014 Phase 1 Live-Data Fixture Validation\n   135\t\n   136\tDate: ${new Date().toISOString()}\n   137\tTask: T816\n   138\tFreshness: fixtureGeneratedAt=${fixture.generatedAt}; outputGeneratedAt=${output.generated_at}\n   139\t\n   140\t## Artifact Package\n   141\t\n   142\tArtifact: ${OUTPUT_PATH}\n   143\tFixture: ${FIXTURE_PATH}\n   144\tExpected: ${EXPECTED_PATH}\n   145\tRun: node ${path.join(__dirname, \"verify_live_phase1_fixture.js\")}\n   146\tVerify: node ${path.join(__dirname, \"verify_live_phase1_fixture.js\")}\n   147\tFreshness: fixtureGeneratedAt=${fixture.generatedAt}; outputGeneratedAt=${output.generated_at}\n   148\t\n   149\t## Verification Summary\n   150\t\n   151\t- Valid normalized markets: ${output.summary.total_markets}\n   152\t- Rejected invalid markets: ${output.summary.rejected_invalid_markets}\n   153\t- After volume filter: ${output.summary.after_volume_filter}\n   154\t- Qualifying markets: ${output.summary.qualifying_markets}\n   155\t- Excluded middle range: ${output.summary.excluded_middle_range}\n   156\t- Extreme ratio manual review: ${output.summary.extreme_ratio}\n   157\t\n   158\t## Expected Contract\n   159\t\n   160\t- Qualifying tickers: ${expected.expectedQualifyingTickers.join(\", \")}\n   161\t- Low-volume excluded tickers: ${lowVolumeTickers.join(\", \")}\n   162\t- Rejected tickers: ${expected.expectedRejectedTickers.join(\", \")}\n   163\t\n   164\t## Sanity Checks\n   165\t\n   166\t${sanityProblems.length === 0 ? \"- PASS: no impossible unemployment, bitcoin dominance, or implausible Solana thresholds detected.\" : sanityProblems.map((problem) => `- FAIL: ${problem}`).join(\"\\n\")}\n   167\t`;\n   168\t\n   169\t  fs.writeFileSync(REPORT_PATH, report);\n   170\t}\n   171\t\n   172\tasync function main() {\n   173\t  const fixture = JSON.parse(fs.readFileSync(FIXTURE_PATH, \"utf8\"));\n   174\t  const expected = JSON.parse(fs.readFileSync(EXPECTED_PATH, \"utf8\"));\n   175\t\n   176\t  const output = await runFilter({\n   177\t    inputPath: FIXTURE_PATH,\n   178\t    outputPath: OUTPUT_PATH,\n   179\t    task: \"T816\",\n   180\t    phase: \"Sprint 6 Phase 1 Live-Data Fixture\",\n   181\t    source: fixture.source,\n   182\t  });\n   183\t\n   184\t  const rawFixtureMarkets = loadMarketsFromFile(FIXTURE_PATH);\n   185\t  const validFixtureMarkets = rawFixtureMarkets.filter((market) => Boolean(market.title || market.name || market.question));\n   186\t  const sanityProblems = validateTitleSanity(validFixtureMarkets);\n   187\t  const outcomeLookup = buildOutcomeLookup({ output, rawFixtureMarkets });\n   188\t  const lowVolumeTickers = [...outcomeLookup.entries()]\n   189\t    .filter(([, outcome]) => outcome === \"excluded_low_volume\")\n   190\t    .map(([ticker]) => ticker);\n   191\t\n   192\t  for (const [key, value] of Object.entries(expected.expectedSummary)) {\n   193\t    assertEqual(output.summary[key], value, `Summary field ${key}`);\n   194\t  }\n   195\t\n   196\t  assertDateNotInFuture(fixture.generatedAt, \"Fixture freshness\");\n   197\t  assertChronologicalOrder(fixture.generatedAt, output.generated_at, \"Fixture output freshness\");\n   198\t\n   199\t  assertArrayEqual(\n   200\t    output.qualifying_markets.map((market) => market.ticker),\n   201\t    expected.expectedQualifyingTickers,\n   202\t    \"Qualifying tickers\"\n   203\t  );\n   204\t\n   205\t  assertArrayEqual(\n   206\t    lowVolumeTickers,\n   207\t    expected.expectedLowVolumeTickers,\n   208\t    \"Low-volume excluded tickers\"\n   209\t  );\n   210\t\n   211\t  assertArrayEqual(\n   212\t    output.rejected_markets.map((market) => market.ticker),\n   213\t    expected.expectedRejectedTickers,\n   214\t    \"Rejected tickers\"\n   215\t  );\n   216\t\n   217\t  assertArrayEqual(\n   218\t    output.excluded_markets.map((market) => `${market.ticker}:${market.reason}`),\n   219\t    expected.expectedExcluded.map((market) => `${market.ticker}:${market.reason}`),\n   220\t    \"Excluded market reasons\"\n   221\t  );\n   222\t\n   223\t  assertEqual(sanityProblems.length, 0, \"Fixture sanity checks\");\n   224\t  for (const [ticker, expectedOutcome] of Object.entries(expected.expectedCaseOutcomes)) {\n   225\t    assertEqual(outcomeLookup.get(ticker), expectedOutcome, `Case outcome for ${ticker}`);\n   226\t  }\n   227\t\n   228\t  writeReport({ fixture, output, expected, sanityProblems, lowVolumeTickers });\n   229\t  console.log(`Verification passed. Output: ${OUTPUT_PATH}`);\n   230\t  console.log(`Report written: ${REPORT_PATH}`);\n   231\t}\n   232\t\n   233\tmain().catch((error) => {\n   234\t  console.error(`Verification failed: ${error.message}`);\n   235\t  process.exit(1);\n   236\t});\n", "exit_code": 0, "status": "completed"}}
