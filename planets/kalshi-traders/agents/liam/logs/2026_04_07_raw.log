,\"p50_ms\":3,\"p99_ms\":506,\"heap_used\":20163288,\"heap_total\":49889280,\"active_agents\":1,\"sse_clients\":1,\"uptime_ms\":274944,\"alerts_fired\":[\"ALT-002\"]}\n{\"timestamp\":\"2026-04-07T16:48:11.031Z\",\"status_code\":200,\"duration_ms\":4,\"p50_ms\":4,\"p99_ms\":506,\"heap_used\":9594280,\"heap_total\":31277056,\"active_agents\":1,\"sse_clients\":0,\"uptime_ms\":304503,\"alerts_fired\":[\"ALT-002\"]}\n{\"timestamp\":\"2026-04-07T16:48:41.029Z\",\"status_code\":200,\"duration_ms\":2,\"p50_ms\":4,\"p99_ms\":506,\"heap_used\":7598416,\"heap_total\":9945088,\"active_agents\":1,\"sse_clients\":0,\"uptime_ms\":334501,\"alerts_fired\":[\"ALT-002\"]}\n{\"timestamp\":\"2026-04-07T16:49:11.030Z\",\"status_code\":200,\"duration_ms\":1,\"p50_ms\":3,\"p99_ms\":506,\"heap_used\":14168456,\"heap_total\":20856832,\"active_agents\":4,\"sse_clients\":0,\"uptime_ms\":364503,\"alerts_fired\":[\"ALT-002\"]}\n{\"timestamp\":\"2026-04-07T16:49:41.165Z\",\"status_code\":200,\"duration_ms\":135,\"p50_ms\":3,\"p99_ms\":506,\"heap_used\":17630744,\"heap_total\":24150016,\"active_agents\":2,\"sse_clients\":0,\"uptime_ms\":394637,\"alerts_fired\":[\"ALT-002\"]}\n","exit_code":0,"status":"completed"}}
