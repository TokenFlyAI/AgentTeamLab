m: HARD DISABLED (10% win rate \u2014 poor performance)\n   352\t  // crypto_edge: HARD DISABLED (11.1% win rate \u2014 poor performance)\n   353\t  // nfp_nowcast: HARD DISABLED (for clean 50-trade run)\n   354\t  // econ_edge: HARD DISABLED (for clean 50-trade run)\n   355\t  const engine = new SignalEngine({ minConfidence: 0.65, minEdge: 1 });  // T334 optimized: confidence=0.65\n   356\t  const sizer = new PositionSizer({ accountBalance: 100000, maxRiskPerTrade: 0.02 });\n   357\t\n   358\t  const meanReversion = new MeanReversionStrategy({ zScoreThreshold: 1.2, minVolume: 10000 });  // T334 optimized: zScore=1.2\n   359\t  // HARD DISABLED per T325: momentum, crypto_edge, nfp_nowcast, econ_edge\n   360\t\n   361\t  const mrSignals = engine.scan(enrichedMarkets, meanReversion);\n   362\t  // All other strategies hard-disabled\n   363\t  const momSignals = [];\n   364\t  const cryptoSignals = [];\n   365\t  const nfpSignals = [];\n   366\t  const econSignals = [];\n   367\t\n   368\t  // 5. Size positions\n   369\t  const marketMap = Object.fromEntries(\n   370\t    enrichedMarkets.flatMap((m) => [[m.id, m], [m.ticker, m]])\n", "exit_code": 0, "status": "completed"}}
