onst observedMax = maxRequestsInSlidingWindow(timestamps, 100);\n   126\t      assert(\n   127\t        observedMax <= 10,\n   128\t        `expected at most 10 requests in any 100ms window, saw ${observedMax}`\n   129\t      );\n   130\t    });\n   131\t  });\n   132\t\n   133\t  await runTest(\"Request metadata is preserved while rate limiting under load\", async () => {\n   134\t    const calls = [];\n   135\t    const client = new KalshiClient({\n   136\t      apiKey: \"test_key_t716\",\n   137\t      demo: false,\n   138\t      rateLimit: { maxRequests: 5, windowMs: 80 },\n   139\t      timeout: 1000,\n   140\t    });\n   141\t\n   142\t    await withMockedHttps(buildMockRequest(calls, () => ({ ok: true })), async () => {\n   143\t      await Promise.all(\n   144\t        Array.from({ length: 12 }, (_, i) =>\n   145\t          client.getCandles(`MARKET-${i}`, {\n   146\t            resolution: \"5m\",\n   147\t            from: 1000 + i,\n   148\t            to: 2000 + i,\n   149\t          })\n   150\t        )\n   151\t      );\n   152\t    });\n   153\t\n   154\t    assert.strictEqual(calls.length, 12, `expected 12 calls, got ${calls.length}`);\n   155\t    calls.forEach((call) => {\n   156\t      assert.strictEqual(call.method, \"GET\");\n   157\t      assert.strictEqual(call.headers.Authorization, \"Bearer test_key_t716\");\n   158\t      assert(\n   159\t        call.url.startsWith(\"https://trading-api.kalshi.com/v1/markets/MARKET-\") &&\n   160\t          call.url.includes(\"/candles?\"),\n   161\t        `unexpected request URL: ${call.url}`\n   162\t      );\n   163\t      const marketId = Number(call.url.match(/MARKET-(\\d+)/)?.[1]);\n   164\t      assert(Number.isInteger(marketId), `expected market id in URL: ${call.url}`);\n   165\t      assert(call.url.includes(\"resolution=5m\"));\n   166\t      assert(call.url.includes(`from=${1000 + marketId}`));\n   167\t      assert(call.url.includes(`to=${2000 + marketId}`));\n   168\t    });\n   169\t  });\n   170\t\n   171\t  await runTest(\"Rate limiter window resets after cooldown\", async () => {\n   172\t    const calls = [];\n   173\t    const client = new KalshiClient({\n   174\t      apiKey: \"test_key_t716\",\n   175\t      demo: true,\n   176\t      rateLimit: { maxRequests: 5, windowMs: 120 },\n   177\t      timeout: 1000,\n   178\t    });\n   179\t\n   180\t    await withMockedHttps(buildMockRequest(calls, () => ({ balance: 10000 })), async () => {\n   181\t      await Promise.all(Array.from({ length: 5 }, () => client.getBalance()));\n   182\t\n   183\t      await new Promise((resolve) => setTimeout(resolve, 150));\n   184\t\n   185\t      const start = Date.now();\n   186\t      await client.getBalance();\n   187\t      const elapsed = Date.now() - start;\n   188\t\n   189\t      assert(\n   190\t        elapsed < 40,\n", "exit_code": 0, "status": "completed"}}
