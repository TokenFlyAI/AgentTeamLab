 fs.writeFileSync(runNumberFile, runNumber.toString());\n   546\t      \n   547\t      const settlement = runSettlement(enrichedMarkets, runNumber);\n   548\t      \n   549\t      if (settlement.settled > 0) {\n   550\t        console.log(`  Settled ${settlement.settled} trades:`);\n   551\t        console.log(`    Wins: ${settlement.wins}, Losses: ${settlement.losses}`);\n   552\t        console.log(`    Total P&L: $${(settlement.totalPnL / 100).toFixed(2)}`);\n   553\t        for (const s of settlement.details.settled) {\n   554\t          console.log(`    - ${s.market}: ${s.outcome} $${(s.pnl / 100).toFixed(2)} (${s.direction} ${s.entryPrice}c \u2192 ${s.exitPrice}c)`);\n   555\t        }\n   556\t      } else {\n   557\t        console.log(`  No trades ready for settlement (${settlement.skipped} skipped)`);\n   558\t      }\n   559\t\n   560\t      finalCapitalFloorStatus = getCapitalFloorStatus(paperTradesDB);\n   561\t      console.log(\"\\n\ud83d\udcb5 Capital floor status after settlement...\");\n   562\t      logCapitalFloorStatus(finalCapitalFloorStatus, \"Post-run\");\n   563\t      if (!tradingHalted && finalCapitalFloorStatus.breached) {\n   564\t        tradingHalted = true;\n   565\t        haltReason = `capital floor breached: current capital $${(finalCapitalFloorStatus.currentCapitalCents / 100).toFixed(2)} below $${(finalCapitalFloorStatus.floorCents / 100).toFixed(2)}`;\n   566\t        if (executionReport && executionReport.halted == null) {\n   567\t          executionReport.halted = true;\n   568\t          executionReport.haltReason = haltReason;\n   569\t        }\n   570\t      }\n   571\t    } catch (settleErr) {\n   572\t      console.log(`  \u26a0\ufe0f  Settlement error: ${settleErr.message}`);\n   573\t    }\n   574\t  }\n   575\t\n   576\t  const report = {\n   577\t    generatedAt: new Date().toISOString(),\n   578\t    source: USE_MOCK_FALLBACK ? \"mock_fallback\" : \"kalshi_live\",\n   579\t    marketCount: enrichedMarkets.length,\n