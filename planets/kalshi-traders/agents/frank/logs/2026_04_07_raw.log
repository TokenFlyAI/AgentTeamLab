{"type":"item.started","item":{"id":"item_31","type":"command_execution","command":"/bin/zsh -lc \"node - <<'NODE'\nconst http = require('http');\nconst samples = [];\nfunction getOnce() {\n  return new Promise((resolve, reject) => {\n    const start = Date.now();\n    const req = http.get('http://localhost:3199/api/health', {headers:{Authorization:'Bearer test'}}, (res) => {\n      res.resume();\n      res.on('end', () => resolve({status:res.statusCode, ms: Date.now()-start}));\n    });\n    req.on('error', reject);\n    req.setTimeout(5000, () => req.destroy(new Error('timeout')));\n  });\n}\n(async () => {\n  for (let i=0;i<20;i++) {\n    try { samples.push(await getOnce()); }\n    catch (err) { samples.push({status:null, error:err.message}); }\n  }\n  console.log(JSON.stringify(samples, null, 2));\n})();\nNODE\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
