{"type": "item.started", "item": {"id": "item_31", "type": "command_execution", "command": "/bin/zsh -lc \"python3 - <<'PY'\nimport sys\nfrom itertools import combinations\nsys.path.insert(0, 'output')\nfrom llm_market_clustering import load_markets, cluster_markets, embed_market, cosine_similarity\nmarkets=load_markets('../grace/output/filtered_markets.json')\nemb={m.ticker: embed_market(m) for m in markets}\nclusters=cluster_markets(markets, threshold=0.65)\nfor c in clusters:\n    if len(c.markets)<2:\n        continue\n    sims=[cosine_similarity(emb[a],emb[b]) for a,b in combinations(c.markets,2)]\n    below=sum(1 for s in sims if s<0.65)\n    print(c.id,c.label,'size',len(c.markets),'min',round(min(sims),3),'mean',round(sum(sims)/len(sims),3),'below_065',below,'of',len(sims))\nPY\"", "aggregated_output": "", "exit_code": null, "status": "in_progress"}}
{"type": "item.completed", "item": {"id": "item_31", "type": "command_execution", "command": "/bin/zsh -lc \"python3 - <<'PY'\nimport sys\nfrom itertools import combinations\nsys.path.insert(0, 'output')\nfrom llm_market_clustering import load_markets, cluster_markets, embed_market, cosine_similarity\nmarkets=load_markets('../grace/output/filtered_markets.json')\nemb={m.ticker: embed_market(m) for m in markets}\nclusters=cluster_markets(markets, threshold=0.65)\nfor c in clusters:\n    if len(c.markets)<2:\n        continue\n    sims=[cosine_similarity(emb[a],emb[b]) for a,b in combinations(c.markets,2)]\n    below=sum(1 for s in sims if s<0.65)\n    print(c.id,c.label,'size',len(c.markets),'min',round(min(sims),3),'mean',round(sum(sims)/len(sims),3),'below_065',below,'of',len(sims))\nPY\"", "aggregated_output": "cluster_4 Politics Markets size 3 min 0.993 mean 0.994 below_065 0 of 3\ncluster_5 Weather Markets size 11 min 0.983 mean 0.995 below_065 0 of 55\ncluster_2 Crypto Markets size 10 min 0.934 mean 0.974 below_065 0 of 45\ncluster_3 Politics Markets size 12 min 0.808 mean 0.934 below_065 0 of 66\ncluster_1 Economics Markets size 14 min 0.256 mean 0.763 below_065 33 of 91\n", "exit_code": 0, "status": "completed"}}
{"type": "item.started", "item": {"id": "item_32", "type": "command_execution", "command": "/bin/zsh -lc \"python3 - <<'PY'\nimport sys\nfrom collections import Counter\nsys.path.insert(0, 'output')\nfrom llm_market_clustering import load_markets, cluster_markets\nmarkets=load_markets('../grace/output/filtered_markets.json')\nbase=cluster_markets(markets, threshold=0.65)\n# dataset leave-one-out: recompute all 50 times and count co-membership retention for baseline pairs\nbase_pairs=set()\nfor c in base:\n    ms=c.markets\n    for i,a in enumerate(ms):\n        for b in ms[i+1:]:\n            base_pairs.add(tuple(sorted((a,b))))\nretained=[]\nfor removed in [m.ticker for m in markets]:\n    subset=[m for m in markets if m.ticker\"'!=removed]\n    cls=cluster_markets(subset, threshold=0.65)\n    pairs=set()\n    for c in cls:\n        ms=c.markets\n        for i,a in enumerate(ms):\n            for b in ms[i+1:]:\n                pairs.add(tuple(sorted((a,b))))\n    overlap=len(base_pairs & pairs)\n    denom=sum(1 for a,b in base_pairs if removed not in (a,b))\n    retained.append(overlap/denom if denom else 1.0)\nprint('\"'dataset_leave_one_out_pair_retention_min', round(min(retained),3))\nprint('dataset_leave_one_out_pair_retention_mean', round(sum(retained)/len(retained),3))\nprint('worst5', sorted((r,m.ticker) for r,m in zip(retained,markets))[:5])\nPY\"", "aggregated_output": "", "exit_code": null, "status": "in_progress"}}
