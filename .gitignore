# Agent logs (can be large)
agents/*/logs/*.log
agents/*/logs/*_raw.log
planets/*/agents/*/logs/*.log
planets/*/agents/*/logs/*_raw.log

# Agent runtime state (changes every cycle — not useful to track)
agents/*/heartbeat.md
agents/*/last_context.md
agents/*/status.md
agents/*/memory.md
agents/*/session_id.txt
agents/*/session_cycle.txt
agents/*/session_id_*.txt
agents/*/session_cycle_*.txt
agents/*/context_snapshot.json
agents/*/logs/cycles/
planets/*/agents/*/heartbeat.md
planets/*/agents/*/last_context.md
planets/*/agents/*/status.md
planets/*/agents/*/memory.md
planets/*/agents/*/session_id.txt
planets/*/agents/*/session_cycle.txt
planets/*/agents/*/session_id_*.txt
planets/*/agents/*/session_cycle_*.txt
planets/*/agents/*/context_snapshot.json
planets/*/agents/*/logs/cycles/

# Agent inboxes, outboxes & processed (ephemeral messages)
agents/*/chat_inbox/
agents/*/chat_outbox*.md
agents/*/processed_inbox/
agents/*/processed/
planets/*/agents/*/chat_inbox/
planets/*/agents/*/chat_outbox*.md
planets/*/agents/*/processed/

# Announcements & team channel (high-volume noise)
public/announcements/
public/team_channel/
planets/*/shared/announcements/
planets/*/shared/team_channel/

# CEO inbox runtime messages
ceo_inbox/
planets/*/data/ceo_inbox/

# Playwright test artifacts
test-results/
playwright-report/

# Task outputs from e2e test runs and agent runtime
public/task_outputs/
planets/*/output/shared/task_outputs/

# Agent cycle failure logs (ephemeral)
planets/*/agents/*/logs/cycle_failures.log

# Runtime context snapshots in agent dirs (prev files)
planets/*/agents/*/*.prev

# SQLite WAL journal files (ephemeral)
backend/messages.db-shm
backend/messages.db-wal
backend/metrics_queue.jsonl
planets/*/data/messages.db-shm
planets/*/data/messages.db-wal
planets/*/data/metrics_queue.jsonl

# Agent runtime output (generated each run — not source)
planets/*/output/*/paper_trade_log.json
planets/*/output/*/paper_trades.db
planets/*/output/*/run_counter.txt
planets/*/output/*/trade_signals.json
planets/*/output/shared/reports/heartbeat_status.json
planets/*/output/shared/reports/health_check_log.jsonl
planets/*/agents/*/tests/integration/*_results.json
planets/*/agents/public/

# Runtime daemon PID files
*.pid
.smart_run_daemon.pid

# Temp config dirs
/tmp/aicompany_config/

# Node
node_modules/

# Python compiled files
__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store

# Archive (optional - remove if you want to track)
public/task_board_archive.md
planets/*/output/shared/codebase/
